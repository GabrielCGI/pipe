      {{parent.Matrix4x4_Inverse.Matrix_InverseResult.matrix} {parent.Matrix4x4_Inverse.Matrix_InverseResult.matrix} {parent.Matrix4x4_Inverse.Matrix_InverseResult.matrix} {parent.Matrix4x4_Inverse.Matrix_InverseResult.matrix}}
      {{parent.Matrix4x4_Inverse.Matrix_InverseResult.matrix} {parent.Matrix4x4_Inverse.Matrix_InverseResult.matrix} {parent.Matrix4x4_Inverse.Matrix_InverseResult.matrix} {parent.Matrix4x4_Inverse.Matrix_InverseResult.matrix}}
      {{parent.Matrix4x4_Inverse.Matrix_InverseResult.matrix} {parent.Matrix4x4_Inverse.Matrix_InverseResult.matrix} {parent.Matrix4x4_Inverse.Matrix_InverseResult.matrix} {parent.Matrix4x4_Inverse.Matrix_InverseResult.matrix}}
    }
  PositionPointGenerator_haperture {{parent.DummyCam.haperture}}
  PositionPointGenerator_vaperture {{parent.DummyCam.vaperture}}
  PositionPointGenerator_focal {{parent.DummyCam.focal}}
  PositionPointGenerator_width {{parent.BBoxToFormat.inputFormat.r}}
  PositionPointGenerator_height {{parent.BBoxToFormat.inputFormat.t}}
  format "2252 942 0 0 2252 942 1 FORMAT_OVERSCAN"
  rebuild_finalise ""
