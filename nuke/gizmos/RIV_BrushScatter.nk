  PositionPointGenerator_childSpread {{parent.iteration_child_spread}}
  PositionPointGenerator_spreadInPlane {{!parent.iteration_spread_axis}}
  PositionPointGenerator_useTexture {{!parent.debug_checkCards}}
  PositionPointGenerator_randomColorTint {{parent.debug_CheckIDs}}
  PositionPointGenerator_useBeauty {{!parent.debug_CheckIDs}}
  PositionPointGenerator_maxLayers {{parent.render_ray_depth}}
  PositionPointGenerator_sizeAlongZ {{parent.scatter_sizealongz}}
  PositionPointGenerator_depthRemapMin {{parent.SAMPLER_NEAR.pixelValues.r}}
  PositionPointGenerator_depthRemapMax {{parent.SAMPLER_FAR.pixelValues.r}}
  PositionPointGenerator_camTransform {
