       {{ShapeAxisS2.world_matrix.0} {ShapeAxisS2.world_matrix.1} {ShapeAxisS2.world_matrix.2}}
       {{ShapeAxisS2.world_matrix.4} {ShapeAxisS2.world_matrix.5} {ShapeAxisS2.world_matrix.6}}
