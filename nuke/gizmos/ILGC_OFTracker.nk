 addUserKnob {22 launchTrack l "Launch Track" T "nuke.thisNode()\['cleanTrack'].execute()\nnuke.thisNode()\['goTrack'].execute()\nnuke.thisNode()\['checkPoint'].setValue(0)" +STARTLINE}
