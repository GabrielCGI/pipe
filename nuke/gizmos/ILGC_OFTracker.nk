Group {
 name ILGC_OFTracker
 knobChanged "\n\nnode=nuke.thisNode()\nknob=nuke.thisKnob()\n\nif knob.name() == \"smooth_curve\" and knob.value() < 0:\n    node\['smooth_curve'].setValue(0)\n\nif knob.name() == \"fadeLength\" and knob.value() < 2:\n    node\['fadeLength'].setValue(2)\nif knob.name() == \"fadeLength\" and knob.value() > 20:\n    node\['fadeLength'].setValue(20)\n\n\nif knob.name() == \"fadeGamma\" and knob.value() < 0.01:\n    node\['fadeGamma'].setValue(0.01)\n  \nif knob.name() == \"customRange\" and knob.value() == True:\n    node\['lastF'].setVisible(False)\n    node\['firstF'].setVisible(False)\n    node\['lastF2'].setVisible(True)\n    node\['firstF2'].setVisible(True)\n    node\['lastF2'].setValue(nuke.root()\[\"last_frame\"].value())\n    node\['firstF2'].setValue(nuke.root()\[\"first_frame\"].value())\nif knob.name() == \"customRange\" and knob.value() == False:\n    node\['lastF'].setVisible(True)\n    node\['firstF'].setVisible(True)\n    node\['lastF2'].setVisible(False)\n    node\['firstF2'].setVisible(False)\n"
 tile_color 0x540054ff
 note_font "Verdana Bold"
 selected true
 xpos -953
 ypos 6475
