 }
 CurveTool {
  operation "Max Luma Pixel"
  ROI {0 0 2 2}
  autocropdata {625 625 1875 1875}
  maxlumapixvalue {0 0 0}
  minlumapixvalue {0 0 0}
  name CurveTool_AutoSize
  xpos -325
  ypos 538
 }
 NoOp {
  inputs 0
  name CODE
  xpos -2
  ypos -224
  addUserKnob {20 User}
  addUserKnob {3 firstFrame l first_frame}
  firstFrame {{"customRange == 0 ? firstF : firstF2"}}
  addUserKnob {3 lastFrame l last_frame -STARTLINE}
  lastFrame {{"customRange == 0 ? lastF : lastF2"}}
  addUserKnob {22 cleanTrack l "Clean Track" T "import nuke\n\nTARGET_KNOBS = \[\n    \"maxlumapixdata\",\n    \"maxlumapixvalue\",\n    \"minlumapixdata\",\n    \"minlumapixvalue\",\n]\n\ndef reset_curve_tool_knobs(node_names, verbose=True):\n    \"\"\"\n    Reset les knobs du CurveTool (ou équivalent) sur plusieurs nodes.\n\n    :param node_names: str ou list\[str]\n    :param verbose: affiche les infos dans le script editor\n    \"\"\"\n\n    if isinstance(node_names, str):\n        node_names = \[node_names]\n\n    for node_name in node_names:\n        node = nuke.toNode(node_name)\n        if not node:\n            if verbose:\n                print(\"Node introuvable :\", node_name)\n            continue\n\n        if verbose:\n            print(\"Traitement de :\", node_name)\n\n        for knob_name in TARGET_KNOBS:\n            if knob_name not in node.knobs():\n                continue\n\n            k = node\[knob_name]\n\n            # retire l'animation (keyframes/curves) si présente\n            try:\n                k.clearAnimated()\n            except Exception:\n                pass\n\n            # nb de composantes (XY=2, RGB=3, float=1, etc.)\n            try:\n                n = k.arraySize()\n            except Exception:\n                n = 1\n\n            # remet à 0 avec la bonne taille\n            try:\n                if n > 1:\n                    k.setValue(\[0.0] * n)\n                else:\n                    k.setValue(0.0)\n            except Exception as e:\n                if verbose:\n                    print(\"  Impossible de reset\", knob_name, \":\", e)\n\n    if verbose:\n        print(\"Terminé.\")\n\nreset_curve_tool_knobs(\[\n    \"CurveTool_Tracker1\",\n    \"CurveTool_AutoSize\",\n])" +STARTLINE}
  addUserKnob {22 goTrack l "Go Track" -STARTLINE T "n = nuke.toNode(\"CurveTool_Tracker1\")\nfirst = int(nuke.thisNode()\['firstFrame'].value())\nlast  = int(nuke.thisNode()\['lastFrame'].value())\nnuke.execute(n, first, last)\n\n\nn = nuke.toNode(\"CurveTool_AutoSize\")\nfirst = int(nuke.thisNode()\['firstFrame'].value())\nlast  = int(nuke.thisNode()\['lastFrame'].value())\nnuke.execute(n, first, last)"}
 }
