  addUserKnob {22 removeS2BTN l "<small><b> ━</b>" t "Remove this shape" -STARTLINE +HIDDEN T "node = nuke.thisNode()\nshape = \"S2\"\n\nnode.knobs()\[\"maskCenter\"+shape+\"CKNB\"].setVisible(False)\nnode.knob(shape+\"TXT\").setVisible(False)\nnode.knobs()\[\"type\"+shape+\"PDC\"].setVisible(False)\nnode.knobs()\[\"operation\"+shape+\"PDC\"].setVisible(False)\nnode.knob(\"invert\"+shape+\"CHK\").setVisible(False)\nnode.knobs()\[\"maskCenter\"+shape+\"CKNB\"].setVisible(False)\nnode.knob(\"radius\"+shape+\"SLD\").setVisible(False)\nnode.knob(\"scale\"+shape+\"3DKNB\").setVisible(False)\nnode.knob(\"rotation\"+shape+\"3DKNB\").setVisible(False)\nnode.knob(\"falloff\"+shape+\"SLD\").setVisible(False)\nnode.knob(\"add\"+shape+\"BTN\").setVisible(False)\nnode.knob(\"remove\"+shape+\"BTN\").setVisible(False)\nnode.knobs()\[\"falloffType\"+shape+\"PDC\"].setVisible(False)\nnode.knob(\"value\"+shape+\"SLD\").setVisible(False)\n\nnode.knobs()\[\"rampStart\"+shape+\"CKNB\"].setVisible(False)\nnode.knobs()\[\"rampEnd\"+shape+\"CKNB\"].setVisible(False)\nnode.knobs()\[\"minorRadius\"+shape+\"SLD\"].setVisible(False)\n\nnuke.toNode(\"Merge\"+shape).knob('disable').setValue(1)\n"}
