 addUserKnob {41 freeze_frame l "freeze frame" T DVProjection.freeze_frame}
 addUserKnob {41 proj_framehold l framehold T DVProjection.proj_framehold}
 addUserKnob {41 setframe l "set current frame" -STARTLINE T DVProjection.setframe}
 addUserKnob {41 proj_zrange l "project z range" T DVProjection.proj_zrange}
 addUserKnob {26 title_output l "<b><font color=#5077FF>output settting</font></b>"}
 addUserKnob {41 output T DVProjection.output}
 addUserKnob {6 premult +STARTLINE}
 premult true
 addUserKnob {20 grp_stmap l "STMap setting" n 1}
 grp_stmap 0
 addUserKnob {41 channels l "apply channels" T DVProjection.channels}
 addUserKnob {41 filter T DVProjection.filter}
 addUserKnob {41 black_outside l "black outside" T DVProjection.black_outside}
 addUserKnob {20 endGroup n -1}
}
