#! C:/Program Files/Nuke15.1v5/nuke-15.1.5.dll -nx
version 15.1 v5
Gizmo {
 inputs 2
 knobChanged "\nnode=nuke.thisNode()\nknob=nuke.thisKnob()\n\nif knob.name() == \"filter_autosize\" and knob.value() == 1:\n    node\['autosize_parameters'].setVisible(True)\n\nelif knob.name() == \"filter_autosize\" and knob.value() == 0:\n    node\['autosize_parameters'].setVisible(False)\nelif knob.name() == \"near_percentage\" and knob.value() > 100 :\n    node\['near_percentage'].setValue(100)\nelif knob.name() == \"near_percentage\" and knob.value() < 0 :\n    node\['near_percentage'].setValue(0)\nelif knob.name() == \"far_percentage\" and knob.value() > 100 :\n    node\['far_percentage'].setValue(100)\nelif knob.name() == \"far_percentage\" and knob.value() < 0 :\n    node\['far_percentage'].setValue(0)\nelif knob.name() == \"KWH_radius_map_remap\" and knob.value() > 1 :\n    node\['KWH_radius_map_remap'].setValue(1)\nelif knob.name() == \"KWH_radius_map_remap\" and knob.value() < -1 :\n    node\['KWH_radius_map_remap'].setValue(-1)\nelif knob.name() == \"brush_mask_projection_remap\" and knob.value() > 1 :\n    node\['brush_mask_projection_remap'].setValue(1)\nelif knob.name() == \"brush_mask_projection_remap\" and knob.value() < -1 :\n    node\['brush_mask_projection_remap'].setValue(-1)\nelif knob.name() == \"KWH_radius_map_noise_gain\" and knob.value() > 1 :\n    node\['KWH_radius_map_noise_gain'].setValue(1)\nelif knob.name() == \"KWH_radius_map_noise_gain\" and knob.value() < 0 :\n    node\['KWH_radius_map_noise_gain'].setValue(0)\nelif knob.name() == \"KWH_radius_map_hair_preserve\" and knob.value() > 1 :\n    node\['KWH_radius_map_hair_preserve'].setValue(1)\nelif knob.name() == \"KWH_radius_map_hair_preserve\" and knob.value() < 0 :\n    node\['KWH_radius_map_hair_preserve'].setValue(0)\nelif knob.name() == \"EC_edgepush_size_out\" and knob.value() < 0 :\n    node\['EC_edgepush_size_out'].setValue(0)\nelif knob.name() == \"EC_edgepush_size_in\" and knob.value() < 0 :\n    node\['EC_edgepush_size_in'].setValue(0)\nelif knob.name() == \"EC_mix\" and knob.value() < 0 :\n    node\['EC_mix'].setValue(0)\nelif knob.name() == \"EC_mix\" and knob.value() > 1 :\n    node\['EC_mix'].setValue(1)\nelif knob.name() == \"EC_amount\" and knob.value() < 1 :\n    node\['EC_amount'].setValue(1)\nelif knob.name() == \"EC_amount\" and knob.value() > 6 :\n    node\['EC_amount'].setValue(6)\nelif knob.name() == \"bbd_gain\" and knob.value() < 0 :\n    node\['bbd_gain'].setValue(0)\nelif knob.name() == \"bbd_mix\" and knob.value() > 1 :\n    node\['bbd_mix'].setValue(1)\nelif knob.name() == \"bbd_mix\" and knob.value() < 0 :\n    node\['bbd_mix'].setValue(0)\nelif knob.name() == \"debug_median_size\" and knob.value() > 10 :\n    node\['debug_median_size'].setValue(10)\nelif knob.name() == \"debug_median_size\" and knob.value() < 0 :\n    node\['debug_median_size'].setValue(0)\n\nelif knob.name() == 'brushes_mode' and knob.value() == \"Interactive\":\n    node\['brush_size'].setVisible(True)\n    node\['brush_offset'].setVisible(True)\n    node\['brush_map1'].setVisible(False)\n    node\['brush_map2'].setVisible(False)\nelif knob.name() == 'brushes_mode' and knob.value() == \"Baked\":\n    node\['brush_map1'].setVisible(True)\n    node\['brush_map2'].setVisible(True)\n    node\['brush_size'].setVisible(False)\n    node\['brush_offset'].setVisible(False)\n\n\nelif knob.name() == \"brush_map1\" and knob.value() > 1 :\n    node\['brush_map1'].setValue(1)\nelif knob.name() == \"brush_map1\" and knob.value() < 0 :\n    node\['brush_map1'].setValue(0)\nelif knob.name() == \"brush_map2\" and knob.value() > 1 :\n    node\['brush_map2'].setValue(1)\nelif knob.name() == \"brush_map2\" and knob.value() < 0 :\n    node\['brush_map2'].setValue(0)\n\nelse:\n    pass\n"
 tile_color 0x540054ff
 note_font "Verdana Bold"
 addUserKnob {20 FUR_TAB l FUR}
 addUserKnob {26 title_presets l "" +STARTLINE T "Presets :"}
 addUserKnob {1 create_preset_name l "Create Preset : Name =>"}
 create_preset_name Standard
 addUserKnob {22 create_preset_go l Go! -STARTLINE T "import nuke\nimport json\n\ndef save_node_knobs_to_json(node, json_path):\n    knob_data = \{\}\n\n    for knob_name in node.knobs():\n        knob = node\[knob_name]\n        try:\n            # Tente de lire la valeur du knob\n            value = knob.value()\n            # Pour les knobs multivaleurs (ex: Position 2D), convertis en liste\n            if isinstance(value, (tuple, list)):\n                value = list(value)\n            knob_data\[knob_name] = value\n        except:\n            # Si le knob ne supporte pas .value() ou pose un problème, on l'ignore\n            continue\n\n    with open(json_path, 'w') as f:\n        json.dump(knob_data, f, indent=4)\n\n# Exemple d'utilisation :\nnode = nuke.thisNode()\npath = \"I:/rivers_feature/04_Resources/nuke/Tools/RIV_StylisedChar/presets/\"\npreset_name = node\['create_preset_name'].getValue()\next = \".json\"\nsave_node_knobs_to_json(node, path+preset_name+ext)"}
 addUserKnob {2 load_preset_path l "Load Preset : Path =>"}
 load_preset_path I:/rivers_feature/04_Resources/nuke/Tools/RIV_StylisedChar/presets/
 addUserKnob {22 load_preset_go l Go! -STARTLINE T "import nuke\nimport json\n\ndef load_knobs_from_json(json_path, node):\n    with open(json_path, 'r') as f:\n        knob_data = json.load(f)\n\n    for knob_name, value in knob_data.items():\n        # 🔽 On ignore \"z_result\"\n        exclude_knobs = \[\"z_result\", \"xpos\", \"ypos\", \"name\"]\n        if knob_name in exclude_knobs:\n            continue\n\n\n        # 🔽 On ignore les champs qui ne sont pas des knobs du node\n        if knob_name not in node.knobs():\n            continue\n\n        knob = node\[knob_name]\n        try:\n            # 🔽 Si c’est une liste, on passe chaque valeur (ex: 2D/3D)\n            if isinstance(value, list):\n                knob.setValue(value)\n            else:\n                knob.setValue(value)\n        except Exception as e:\n            print(f\"❌ Impossible de définir la valeur pour le knob '\{knob_name\}': \{e\}\")\n\n# Exemple d’utilisation :\nnode = nuke.thisNode()\npath = node\['load_preset_path'].getValue()\nload_knobs_from_json(path , node)\n"}
