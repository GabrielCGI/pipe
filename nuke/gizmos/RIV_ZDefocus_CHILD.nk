version 15.1 v5
push $cut_paste_input
Group {
 name RIV_ZDefocus_CHILD
 tile_color 0x540054ff
 note_font "Verdana Bold"
 selected true
 xpos 3213
 ypos -7678
 addUserKnob {20 DOF}
 addUserKnob {26 title01 l "" +STARTLINE T "Focal Point :"}
 addUserKnob {6 check_layer_setup l "Check Layer Setup" +STARTLINE}
 addUserKnob {7 mix_ls l "" -STARTLINE}
 mix_ls 0.5
 addUserKnob {41 autofocus +INVISIBLE T PxF_DeepDefocus.autofocus}
 addUserKnob {41 focalDistance l "focus plane" -STARTLINE +INVISIBLE T PxF_DeepDefocus.focalDistance}
 addUserKnob {41 nearPick l "znear picker" +INVISIBLE T PxF_DeepDefocus.nearPick}
 addUserKnob {41 znear -STARTLINE +INVISIBLE T PxF_DeepDefocus.znear}
 addUserKnob {41 farPick l "zfar picker" +INVISIBLE T PxF_DeepDefocus.farPick}
