 addUserKnob {26 ""}
 addUserKnob {26 title02 l "" +STARTLINE T "Stylized Dof :"}
 addUserKnob {6 def_edges_filter l "Filter Edges" +STARTLINE}
 def_edges_filter {{parent.RIV_ZDefocus_MASTER.def_edges_filter}}
 addUserKnob {7 mix_edges l "" -STARTLINE}
 mix_edges {{parent.RIV_ZDefocus_MASTER.mix_edges}}
 addUserKnob {7 def_size l Size R 0 75}
 def_size {{parent.RIV_ZDefocus_MASTER.def_size*mult01}}
 addUserKnob {7 mult01 l mult -STARTLINE R 0 4}
 mult01 1
 addUserKnob {7 def_front_size l "Front Multiplier" R 0 5}
 def_front_size {{parent.RIV_ZDefocus_MASTER.def_front_size*mult02}}
 addUserKnob {7 mult02 l mult -STARTLINE R 0 4}
 mult02 1
 addUserKnob {7 def_back_size l "Back Multiplier" R 0 5}
 def_back_size {{parent.RIV_ZDefocus_MASTER.def_back_size*mult03}}
 addUserKnob {7 mult03 l mult -STARTLINE R 0 4}
 mult03 1
 addUserKnob {7 focus_region_size l "Focus Region Size" R 0 10}
 focus_region_size {{parent.RIV_ZDefocus_MASTER.focus_region_size}}
 addUserKnob {7 front_region_size l "Front Region Size" R 0 10}
 front_region_size {{parent.RIV_ZDefocus_MASTER.front_region_size}}
 addUserKnob {7 back_region_size l "Back Region Size" R 0 10}
 back_region_size {{parent.RIV_ZDefocus_MASTER.back_region_size}}
 addUserKnob {26 ""}
 addUserKnob {26 title03 l "" +STARTLINE T "Real Dof : "}
 addUserKnob {68 filter_mode l "Filter Mode" M {defocus bokeh ""}}
 filter_mode bokeh
 addUserKnob {7 rdef_size l Size R 0 75}
 rdef_size {{parent.RIV_ZDefocus_MASTER.rdef_size*mult04}}
 addUserKnob {7 mult04 l mult -STARTLINE R 0 4}
 mult04 1
 addUserKnob {7 rdef_max_size l "Max Size" R 0 150}
 rdef_max_size {{parent.RIV_ZDefocus_MASTER.rdef_max_size*mult05}}
 addUserKnob {7 mult05 l mult -STARTLINE R 0 4}
 mult05 1
 addUserKnob {26 ""}
 addUserKnob {26 titltle04 l "" +STARTLINE T "Mask :"}
 addUserKnob {6 mask_invert l invert -STARTLINE}
 mask_invert true
 addUserKnob {6 mask_premult l premult -STARTLINE}
 addUserKnob {20 INFO_TAB l INFO}
 addUserKnob {26 info_text l "" +STARTLINE T "info : tool built @ Illogic Studios for ITM.\npass needed : depth\n\n_____________________\n\nreleases: \nv0.1 : first release\nv0.2 : mask settings added / cleaner edge filtering / bokeh input added / additional options on childs"}
}
