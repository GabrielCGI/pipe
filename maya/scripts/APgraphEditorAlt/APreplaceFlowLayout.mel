			    iconTextButton -p $APflow -w 23 -h 23 -bgc 0.365 0.365 0.365 -ann "Click = Globaly align selected Keys values on the First value of all Selected Keys\nShift+Click = Relative align selected Keys values on the First value of all Selected Keys" -i ($APgraphAltIconPath+"alignLeft.png")  -c APgraphKeystoFirstSwitcher -l "x--";
			    iconTextButton -p $APflow -w 23 -h 23 -bgc 0.365 0.365 0.365 -ann "Click = Globaly align selected Keys values on the Last value of all Selected Keys\nShift+Click = Relative align selected Keys values on the Last value of all Selected Keys" -i ($APgraphAltIconPath+"alignRight.png")  -c APgraphKeystoLastSwitcher -l "--x";
