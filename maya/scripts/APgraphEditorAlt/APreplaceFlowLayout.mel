			    //iconTextButton -p $APflow  -style "iconOnly" -i "modifyStraighten" -ann "Align Selected Keys values on a slope drawn between the first and last key of the selection" -w 24 -h 24 -c APrebuildSlope -l "/";	
		    
	    }
	  
	}
formLayout -e -w 610 "graphEditorKeyframeStatsLayout";
}

global proc APscaleKeyFromFlowPPM(string $ppm)
{
  popupMenu -e -dai $ppm;
  menuItem -p $ppm -l "Set Scale Ratio" -c "APdefineScaleRatioGraphAlt";
  menuItem -p $ppm -l "Preserve Curves Tangent Type" -cb `optionVar -q APskipTangentsSmooth` -c ("optionVar -iv APskipTangentsSmooth #1");
}

global proc APdefineScaleRatioGraphAlt()
{
  string $text;
  string $ratio = `optionVar -q APscaleRatioGraphAlt`;
  string $result = `promptDialog
      -title "Scale ratio"
      -message "Enter New Ratio"
      -button "OK" -tx $ratio -button "Cancel"
      -defaultButton "OK" -cancelButton "Cancel"
      -dismissString "Cancel"`;

  if ($result == "OK") 
  {
    if(`promptDialog -query -text` != "")
    {
	optionVar -fv APscaleRatioGraphAlt (float(`promptDialog -query -text`));
    }
  }
}

global proc APreverseTiming()
{
  
  float $d[] = `keyframe -q -tc`;
  if(`size $d`)
  {
  float $f[] = sort($d);
  float $timePivot =  ($f[0]+(($f[`size $f`-1]-$f[0])/2.0));
  scaleKey -iub false -ts -1 -tp $timePivot -fs 1 -fp $timePivot -vs 1 -animation keys;
  }
  else
    error "No Key selected";
}

global proc APreverseValues()
{
    float $scale = `optionVar -q APscaleRatioGraphAlt`;
    optionVar -fv APscaleRatioGraphAlt 2.0;
    if(`getModifiers` == 0 )
    {
      APperCurveSetRelativeKeyScaleFromFirst(0);
    }
    
    if(`getModifiers` == 12 )
    {
      APperCurveSetRelativeKeyScaleFromFirst(1);
    }
    optionVar -fv APscaleRatioGraphAlt $scale;
    //print `getModifiers`;
}


global proc APreverseValues2()
{
float $d[] = `keyframe -q -tc`;
float $v[] = `keyframe -q -vc`;
  if(`size $d`)
  {
  float $f[] = sort($d);
  float $e[] = sort($v);
  float $valuePivot =  ($v[0]+(($v[`size $v`-1]-$v[0])/2.0));
  //scaleKey -iub false -ts -1 -tp $timePivot -fs 1 -fp $timePivot -vs 1 -animation keys;
    if(`getModifiers` == 0 )
    {
      scaleKey -scaleSpecifiedKeys 1 -timeScale 0 -timePivot $f[0] -floatScale 0 -floatPivot $f[0] -valueScale -1 -valuePivot $v[0] -animation keys;
    }
    if(`getModifiers` == 4 )
    {
      scaleKey -scaleSpecifiedKeys 1 -timeScale 0 -timePivot $f[0] -floatScale 0 -floatPivot $f[0] -valueScale -1 -valuePivot $v[`size $v`-1] -animation keys;
    }
  }
  else
    error "No Key selected";

}




global proc APmoveAllKeyToCurrentTime()
{
 //scaleKey -scaleSpecifiedKeys 1 -newStartTime `currentTime -q` -newStartFloat `currentTime -q` -newEndTime (`currentTime -q`+`rand 0 0.05`) ` -newEndFloat (`currentTime -q`+`rand 0 0.05`); 
 keyframe -a -o over -t (`currentTime -q`+`rand 0 0.05`); 
}

global proc APlaunchGrapEditorHelp()
{
   global string $APgraphEditorAltPath;
    if(!`optionVar -ex "APoccCheckLanguage"`)
    {optionVar -sv "APoccCheckLanguage" "#";}
    
    if(`optionVar -q "APoccCheckLanguage"` == "#")
    {
      //print ($APyouMovePath+"DOC_FR/doc.html\n");
      APshowHelp(($APgraphEditorAltPath+"DOC/index_fr.html"),1);
    }
    if(`optionVar -q "APoccCheckLanguage"` == "&")
    {
       //print ($APyouMovePath+"DOC_EN/doc.html\n");
       APshowHelp(($APgraphEditorAltPath+"DOC/index_en.html"),1);
    } 
}

global proc APalignSelKeysOnCurrentFrame()
{
  
 string $selectedCurves[] = `keyframe -q -n -sl`;
for ($c in $selectedCurves)
{
    float $time = `currentTime -q`;
    
float $vals[];
$vals = `keyframe -t $time -q  -vc -query $c`;  
if(`size $vals`)   
{keyframe -e -iub true  -a -o move -tc `currentTime -q` $c;}

}

}

global proc APsmoothKeys ()
{
  oaSmoothKeys; 
  aTan_smoothKeys2(0.25,1);
}


global proc APnoiseKey(float $amp, float $step, int $preserveIn, int $preserveOut, int $onlySelection)
{
  python("import time");
  string $selectedCurves[] = `keyframe -q -n -sl`; 

  if (`size $selectedCurves`)
  {
      for ($curv in $selectedCurves)
      {
	    float $valdT[] = `keyframe -q -tc -sl $curv`;
	    float $valdV[] = `keyframe -q -vc -sl $curv`;
	    int $i = 0;
	    float $stamp = float(python("str(time.time())"));
	    seed(int($stamp));
	    for($f in $valdT)
	    {
		
		float $valRand = `rand ($valdV[$i]-$amp) ($valdV[$i]+$amp)`;
		string $cmd = ("keyframe -t "+$valdT[$i]+" -valueChange "+$valRand) ;
		
		  // print ($cmd+" "+$curv);
		//print ($cmd+$curv);
		eval($cmd+" "+$curv);
		$i++;
	    }
	      //keyTangent -itt flat -ott flat;
	      //scaleKey -iub false -ts 1 -iub 1 -t ($valdT[0]+":"+($valdT[`size $valdT`-1]+1)) -tp 176 -fs 1 -fp 176 -vs 0.9 -vp -1.352171619 Scarlet:FULL:neck_02_rotateZ
      }
    //keyTangent -itt flat -ott $outTan[0];
  } 
}

global proc APnoiseKey2(float $amp, float $step, int $preserveIn, int $preserveOut, int $onlySelection)
{
	global string $gPlayBackSlider;
	float $range[] = `keyframe -q -tc -sl`;
	//float $values[] = `keyframe -q -vc -sl`;
	string $sel[] = `ls -sl`;
	int $u;
	//float $step = 1;
	float $val[];
	clear $val;
    string $curves[] = `selectionConnection -q -obj "keyframeList"`;
    string $attrs[];
    //APverbosePrint(stringArrayToString($curves, " ")); 
  
    for ($curve in $curves)
    {
    	string $t[] = `listConnections -s 0 -d 1 -p 1 $curve`;
    	$attrs[`size $attrs`] = $t[0];
    }	
	
	for ($attr in $attrs)
	 {
            $sel[0] = `plugNode $attr`;
			int $i=(0+$preserveIn);
			for ($u=($range[0]+$preserveIn); $u<=($range[`size $range`-1]-$preserveOut); $u+=$step)
			{
                if ($onlySelection)
                {                
                    //print ("U="+$u+"\n");
                                  
                    if ($u == $range[$i])
                    {				
                       // print ("rang="+$range[$i]+"\n") ;        				
        				$val[`size $val`] = `getAttr -t $u $attr`;
        				$i+=1;
     				}
     				
				}
				else
				{
				    $val[`size $val`] = `getAttr -t $u $attr`;
				}
				
			}
			float $shorterList[] = APfloatArrayRemoveDuplicates($val,0);
			float $sum=0;
            for ($va in $shorterList)
            {
                $sum+=$va;
            }
	    int $size = `size $shorterList`;
	    if ($size == 0)
	    {$size = 1;}
            float $aver = ($sum/$size);
            $amp = `abs $aver`;
	    if ($amp == 0)
	    {$amp = 10;}
            //print ($amp+"\n");   
			int $y=(0+$preserveIn);
			$i=0;
			for ($u=($range[0]+$preserveIn); $u<=($range[`size $range`-1]-$preserveOut); $u+=$step)
			{
                if ($onlySelection)
                {                
                    if ($u == $range[$y])
                    {				
        				setKeyframe -s 0 -t $u -at `plugAttr($attr)` -v `rand ($val[$i]-$amp) ($val[$i]+$amp)` $attr;
        				$y+=1;
        				$i+=1;
    				}
				}
				else
				{
				    setKeyframe -s 0 -t $u -at `plugAttr($attr)` -v `rand ($val[$i]-$amp) ($val[$i]+$amp)` $attr;
				    $i+=1;
				}
				//				
			}
	}
}

global proc APdoNoise(int $resample, float $step, float $power)
{
  if($resample == 1)
  {
    string $curves[] = `keyframe -q -sl -n`;
    float $keyss[] = sort(`keyframe -q -sl -tc`);
    for($curv in $curves)
    {
      //float $keyss[] = sort(`keyframe -q -sl -tc $curv`);
      int $size = `size $keyss`;
      catchQuiet(`filterCurve -f resample  -kernel lirp -startTime ($keyss[0]-1) -endTime ($keyss[$size-1]+1) -period $step  $curv`);
      APnoiseKey($power, 1, `optionVar -q APdoPreserveIn`, `optionVar -q APdoPreserveOut`, `optionVar -q APonlySelection` );
    }
  }
  
}

