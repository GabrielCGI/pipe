//{
  //popupMenu -e -dai $ppm;
  //menuItem -p $ppm -c ("optionVar -iv APkeepAutoTangentAlive (1-`optionVar -q APkeepAutoTangentAlive`)") -cb `optionVar -q "APkeepAutoTangentAlive"` -l "Keep Alive";  
