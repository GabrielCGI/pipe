global proc APbuidMenuSmooth( string $ppm )
{
  
  popupMenu -e -dai $ppm;
  menuItem -p $ppm -c ("optionVar -iv APkeepAutoTangentAlive (1-`optionVar -q APkeepAutoTangentAlive`)") -cb `optionVar -q "APkeepAutoTangentAlive"` -l "Live Tangents";
  menuItem -p $ppm -d 1;
  float $i = 0;
  for ($i=0; $i<=100; $i+=25)
  {	
    if (($i/100) == `optionVar -q "aTan_softness"`)
    {
      string $mm = `menuItem -p $ppm -l ("- "+$i+" -") -bld 1 -sm 1`;
      //setParent -m $ppm;
      menuItem -e -pmc ("optionVar -fv aTan_softness "+($i/100)+"; aTan_smoothKeys22("+($i/100)+",1)") $mm;
      
    }
    else
    {
      string $mm = `menuItem -p $ppm -l ("  "+$i +"  ")-sm 1`;
      //setParent -m $ppm;
      menuItem -e -pmc ("optionVar -fv aTan_softness "+($i/100)+"; aTan_smoothKeys22("+($i/100)+",1)") $mm;
      
    }
  }
}

global proc APrebuildSlope()
{
	float $times[]  = `keyframe -q`;
	string $selList[] = `selectionConnection -q -obj "keyframeList"`;
	if (`size $times`)
	{
    	int $index=0;
    	selectKey -clear ;
    	cutKey -cl -time ($times[1]+":"+$times[`size $times`-2]) $selList;
    	string $evalCmd = "setKeyframe -s 0 -i";
    	string $evalCmd2 = "selectKey -add -k";
    	for ($t in $times)
    	{
    	    $evalCmd+= (" -t "+$t);
            $evalCmd2+= (" -t "+$t);	
    	}
    	eval ($evalCmd+ " "+ $selList[0]);
    	eval ($evalCmd2+ " "+ $selList[0]);
    	keyTangent -itt linear -ott linear $selList;
	}
}

global proc APsetKeyValToUpperBound()
{
    float $val[] = `keyframe -q -vc -sl`;
    if (`size $val`)
    {
        $val = `sort $val`;
        keyframe -animation keys -absolute -valueChange $val[`size $val`-1];
        catchQuiet(APautoSmoothKeysSwitch());
    }
}

global proc APgraphKeystoUpperBoundSwitcher()
{
 if(`getModifiers`==1)
 {
   APsetKeyValToUpperBound;
 }
 else
 {
   APperCurveSetKeyValToUpperBound;
 }
}

global proc APgraphKeystoFirstSwitcher()
{
 if(`getModifiers`==1)
 {
   //APsetKeyValToFirst;
   APperCurveSetRelativeKeyValToFirst;
 }
 else
 {
   APperCurveSetKeyValToFirst;
 }
}

global proc APgraphKeystoLastSwitcher()
{
 if(`getModifiers`==1)
 {
   //APsetKeyValToLast;
   APperCurveSetRelativeKeyValToLast;
 }
 else
 {
   APperCurveSetKeyValToLast;
 }
}

global proc APgraphKeystoLowerBoundSwitcher()
{
 if(`getModifiers`==1)
 {
   APsetKeyValToLowerBound;
 }
 else
 {
   APperCurveSetKeyValToLowerBound;
 }
}

global proc APperCurveSetKeyValToUpperBound()
{
	string $selectedCurves[] = `keyframe -q -n -sl`;
	float $valdd[];
	float $vald[];
	clear $valdd;
	clear $vald;
	string $cmd = "";
	string $outTan[];
	if (`size $selectedCurves`)
	{
	  for ($curv in $selectedCurves)
	  {
	      $valdd = `keyframe -q -vc -sl $curv`;
	      int $index[] = `keyframe -q -sl -iv $curv`;
	      int $lastID = $index[`size $index`-1];
	      $outTan = `keyTangent -index $lastID -q -ott $curv`;
	      if (!`size $valdd`)
	      {
		$valdd = `keyframe -q -vc $curv`;
		$index = `keyframe -q -sl -iv $curv`;
	      }
	      
	      $vald = `sort $valdd`;
	      int $lstVal = (`size $vald`-1);
	      string $cmd = ("keyframe -e -absolute -valueChange "+$vald[$lstVal]);
	      int $in;
	      for ($in in $index)
	      {$cmd+= (" -index "+$in+" ");}
	      eval($cmd+$curv);
	      keyTangent -itt flat -ott flat;
	      
	  }
	  keyTangent -itt flat -ott $outTan[0];
	}
}

global proc APperCurveSetRelativeKeyValToFirst()
{
	string $selectedCurves[] = `keyframe -q -n -sl`;
	float $valdd[];
	float $vald[];
	clear $valdd;
	clear $vald;
	string $cmd = "";
	string $outTan[]; string $curv;
	if (`size $selectedCurves`)
	{
	  for ($curv in $selectedCurves)
	  {
	      $valdd = `keyframe -q -vc -sl $curv`;
	      float $aver;
	      int $i = 1;
	      for ($i = 1; $i<`size $valdd`; $i++)
	      {
	          $aver+= $valdd[$i];
	      }
	      float $average = ($aver/(`size $valdd`-1));
	      int $index[] = `keyframe -q -sl -iv $curv`;
	      int $firstID = $index[0];
	      $outTan = `keyTangent -index $firstID -q -ott $curv`;

	      
	      string $cmd = ("keyframe -e -relative -valueChange "+($valdd[0]-$valdd[1]));
	      int $in;
	      //for ($in in $index)
	      //{$cmd+= (" -index "+$in+" ");}
	      $i = 1;
	      for ($i = 1; $i<`size $valdd`; $i++)
	      {
	          $cmd+= (" -index "+$index[$i]+" ");
	      }
	      //print ($cmd+$curv);
	      eval($cmd+$curv);
	      //keyTangent -itt flat -ott flat;
	      
	  }
	  //keyTangent -itt flat -ott $outTan[0];
	} 
}

global proc APperCurveSetRelativeKeyScaleFromFirst(int $mode)
{
   float $way = `optionVar -q APscaleRatioGraphAlt`;
    if (`getModifiers` == 1 || `getModifiers` == 5)
    {
      $way *= -1;
    }
    
    
 string $selectedCurves[] = `keyframe -q -n -sl`;
	float $valdT[];
	float $valdV[];
	float $vald[];
	clear $valdV;
	clear $valdT;
	clear $vald;
	string $cmd = "";
	string $outTan[]; string $curv;
	//print $way;
	float $value = (1-$way);
	if (`size $selectedCurves`)
	{
	  for ($curv in $selectedCurves)
	  {
	      $valdT = `keyframe -q -tc -sl $curv`;
	      $valdV = `keyframe -q -vc -sl $curv`;
	      if(`getModifiers` == 4 || `getModifiers` == 5)
	      {
		float $avrVal;
		for ($v in $valdV)
		{
		  $avrVal+=$v;
		}
		$valdV[0] = ($avrVal/(`size $valdV`*1.0));
		//print ("\naverage = "+$valdV[0]);
	      }
	      else
	      {
	         if($mode)
	         {$valdV[0] = $valdV[`size $valdV`-1];}
	      }
	     // print $value;
	      string $cmd = ("scaleKey -ts 1 -iub 1 -t "+"\""+$valdT[0]+":"+($valdT[`size $valdT`-1])+"\""+" -tp "+$valdT[0]+" -fs 1 -fp "+$valdV[0]+" -vs "+$value+" -vp "+$valdV[0]) ;
	      
           // print ($cmd+" "+$curv);
	      //print ($cmd+$curv);
	      eval($cmd+" "+$curv);
	      //keyTangent -itt flat -ott flat;
	      //scaleKey -iub false -ts 1 -iub 1 -t ($valdT[0]+":"+($valdT[`size $valdT`-1]+1)) -tp 176 -fs 1 -fp 176 -vs 0.9 -vp -1.352171619 Scarlet:FULL:neck_02_rotateZ
	  }
	  //keyTangent -itt flat -ott $outTan[0];
	} 
	catchQuiet(APautoSmoothKeysSwitch());
}


