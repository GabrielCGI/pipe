				menuItem -p $ppmm -cb `optionVar -q APdoPreserveOut` -c ("optionVar -iv APonlySelection (1-`optionVar -q APdoPreserveOut`)") -l "Preserve OUT";
				menuItem -p $ppmm -cb `optionVar -q APonlySelection` -c ("optionVar -iv APonlySelection (1-`optionVar -q APonlySelection`)") -l "On Selection Only";
			    //button -p $APflow -w 50 -ann "Smooth Selected Keys" -c APsmoothKeys -l "Smooth";
			      
			    //button  -p $APflow -l "Auto Tangents" -bgc 0.89 0.43 0.47 -c "trdprty_tungsethTangent" -ann "Auto tangents" -w 90 -h 24;
