global proc APsetKeyValToZero()
{
    string $tangType[] = `keyTangent -q -ott`;
    keyframe -animation keys -absolute -valueChange 0;
    if ($tangType[size (`keyTangent -q -ott`)-1]=="step")
    {keyTangent -ott step;}
    else
    {aTan_smoothKeys2(0.0,1);}
}

global proc APresetKeyToDefault()
{
        if (`getModifiers` == 1)
	{
	  
	  APsetKeyValToZero();
	}
	else
	{
	  string $selectedCurves[] = `keyframe -q -n -sl`;
	  float $valdd[];
	  float $vald[];
	  clear $valdd;
	  clear $vald;
	  string $cmd = "";
	  string $outTan[];
	  if (`size $selectedCurves`)
	  {
	    for ($curv in $selectedCurves)
	    {
		$valdd = `keyframe -q -vc -sl $curv`;
		int $index[] = `keyframe -q -sl -iv $curv`;
		int $lastID = $index[`size $index`-1];
		$outTan = `keyTangent -index $lastID -q -ott $curv`;
		if (!`size $valdd`)
		{
		  $valdd = `keyframe -q -vc $curv`;
		  $index = `keyframe -q -sl -iv $curv`;
		}
		string $attrs[] = `listConnections -s 0 -d 1 -p 1 $curv`;
		float $val;
		
		if (`gmatch $attrs[0] "*translateX"` || `gmatch $attrs[0] "*translateY"` || `gmatch $attrs[0] "*translateZ"`)
			    $val=0;
		    else if (`gmatch $attrs[0] "*rotateX"` || `gmatch $attrs[0] "*rotateY"` || `gmatch $attrs[0] "*rotateZ"`)
			    $val=0;
		    else if (`gmatch $attrs[0] "*scaleX"` || `gmatch $attrs[0] "*scaleY"` || `gmatch $attrs[0] "*scaleZ"`)
			    $val=1;
		else
		    { 
		      if(catchQuiet(`addAttr -q -dv $attrs[0]`))
		      {
			$val = `addAttr -q -dv $attrs[0]`; 
		      }
		    }
		
	      
		string $cmd = ("keyframe -e -absolute -valueChange "+$val);
		int $in;
		for ($in in $index)
		{$cmd+= (" -index "+$in+" ");}
		eval($cmd+$curv);
		
		keyTangent -itt flat -ott flat;
	    }
	    if(!`optionVar -q APskipTangentsSmooth`)
	    {keyTangent -itt flat -ott $outTan[0];}
	  }
	}
}

global proc APsetKeyValToLowerBound()
{
    float $val[] = `keyframe -q -vc -sl`;
    if (`size $val`)
    {
        $val = `sort $val`;
        keyframe -animation keys -absolute -valueChange $val[0];
        catchQuiet(APautoSmoothKeysSwitch());
    }
}

global proc APsetKeyValToFirst()
{
    float $val[] = `keyframe -q -vc -sl`;
    if (`size $val`)
    {
        string $tangType[] = `keyTangent -q -ott`;
	keyframe -animation keys -absolute -valueChange $val[0];
        if ($tangType[size (`keyTangent -q -ott`)-1]=="step")
	{keyTangent -ott step;}
	else
	{aTan_smoothKeys2(0.0,1);}
    }
}

global proc APsetKeyValToLast()
{
    float $val[] = `keyframe -q -vc -sl`;
    if (`size $val`)
    {
        string $tangType[] = `keyTangent -q -ott`;
	keyframe -animation keys -absolute -valueChange $val[`size $val`-1];
        if ($tangType[size (`keyTangent -q -ott`)-1]=="step")
	{keyTangent -ott step;}
	else
	{aTan_smoothKeys2(0.0,1);}
    }
}

global proc APsetKeyValToAverageBound()
{
    float $val[] = `keyframe -q -vc -sl`;
    if (`size $val`)
    {
        float $sum = 0;
	float $shorterList[] = APfloatArrayRemoveDuplicates($val,0);
        for ($va in $shorterList)
        {
            $sum+=$va;
        }
        keyframe -animation keys -absolute -valueChange ($sum/(`size $shorterList`));
        aTan_smoothKeys2(0.0,1);
    }
}

global proc APbuildAltKeyStats()
{
	string $form = `formLayout -w 210`;
	global string $APtimeFloatFieldGE;
	$APtimeFloatFieldGE = `floatField -p $form -pre 4`;
	string $buttonTime = `iconTextButton -c ("floatField -e -v 0 "+"\""+$APtimeFloatFieldGE+"\"")  -style "textOnly" -p $form -w 15 -h 24 -l "T"`;
	string $buttonTimeAdd = `iconTextButton -style "textOnly" -c ("APsetTimeFloatFieldCmd(`floatField -q -v "+"\""+$APtimeFloatFieldGE+"\""+"`)") -p $form -w 20 -h 24 -l "+="`;
	    popupMenu -b 3 -p $buttonTimeAdd;
	        menuItem -c ("global string $APsetGlobalMoveModeGE; $APsetGlobalMoveModeGE = "+"\""+"-"+"\""+";iconTextButton -e -l "+"\""+"-="+"\""+ " "+"\""+$buttonTimeAdd+"\"") -l "-";
	        menuItem -c ("global string $APsetGlobalMoveModeGE; $APsetGlobalMoveModeGE = "+"\""+":"+"\""+";iconTextButton -e -l "+"\""+":="+"\""+ " "+"\""+$buttonTimeAdd+"\"") -l ":";
	        menuItem -c ("global string $APsetGlobalMoveModeGE; $APsetGlobalMoveModeGE = "+"\""+"x"+"\""+";iconTextButton -e -l "+"\""+"x="+"\""+ " "+"\""+$buttonTimeAdd+"\"") -l "x";
	        menuItem -c ("global string $APsetGlobalMoveModeGE; $APsetGlobalMoveModeGE = "+"\""+"+"+"\""+";iconTextButton -e -l "+"\""+"+="+"\""+ " "+"\""+$buttonTimeAdd+"\"") -l "+";
	global string $APvalueFloatFieldGE;
	$APvalueFloatFieldGE = `floatField -p $form -pre 4`;
	string $buttonValue = `iconTextButton -c ("floatField -e -v 0 "+"\""+$APvalueFloatFieldGE+"\"") -dcc ("floatField -e -v 0 "+"\""+$APvalueFloatFieldGE+"\""+";APsetKeyValToZero") -style "textOnly" -p $form -w 15 -h 24 -l "V"`;
	string $buttonValueAdd = `iconTextButton -style "textOnly" -c ("APsetValueFloatFieldCmd(`floatField -q -v "+"\""+$APvalueFloatFieldGE+"\""+"`)") -p $form -w 20 -h 24 -l "+="`;
		popupMenu -b 3 -p $buttonValueAdd;
	        menuItem -c ("global string $APsetGlobalMoveModeGE; $APsetGlobalMoveModeGE = "+"\""+"-"+"\""+"; iconTextButton -e -l "+"\""+"-="+"\""+ " "+"\""+$buttonValueAdd+"\"") -l "-";
	        menuItem -c ("global string $APsetGlobalMoveModeGE; $APsetGlobalMoveModeGE = "+"\""+":"+"\""+";iconTextButton -e -l "+"\""+":="+"\""+ " "+"\""+$buttonValueAdd+"\"") -l ":";
	        menuItem -c ("global string $APsetGlobalMoveModeGE; $APsetGlobalMoveModeGE = "+"\""+"x"+"\""+";iconTextButton -e -l "+"\""+"x="+"\""+ " "+"\""+$buttonValueAdd+"\"") -l "x";
	        menuItem -c ("global string $APsetGlobalMoveModeGE; $APsetGlobalMoveModeGE = "+"\""+"+"+"\""+";iconTextButton -e -l "+"\""+"+="+"\""+ " "+"\""+$buttonValueAdd+"\"") -l "+";
	floatField -e -ec ("APsetValueFloatFieldAbsCmd(`floatField -q -v "+"\""+$APvalueFloatFieldGE+"\""+"`)") $APvalueFloatFieldGE;
	floatField -e -ec ("APsetTimeFloatFieldAbsCmd(`floatField -q -v "+"\""+$APtimeFloatFieldGE+"\""+"`)") $APtimeFloatFieldGE;
	//-cc ("APsetTimeFloatFieldCmd(`floatField -q -v "+"\""+$APtimeFloatFieldGE+"\""+"`)")
	formLayout -e
	-af $buttonTime "top" 0
	-af $buttonTime "bottom" 0
	-af $buttonTime "left" 0
	-an $buttonTime "right"
	
	-af $buttonTimeAdd "top" 0
	-af $buttonTimeAdd "bottom" 0
	-ac $buttonTimeAdd "left" 0 $buttonTime
	-an $buttonTimeAdd "right"
	
	-af $APtimeFloatFieldGE "top" 0
	-af $APtimeFloatFieldGE "bottom" 0
	-ac $APtimeFloatFieldGE "left" 0 $buttonTimeAdd
	-an $APtimeFloatFieldGE "right" 
	
	-af $buttonValue "top" 0
	-af $buttonValue "bottom" 0
	-ac $buttonValue "left" 10 $APtimeFloatFieldGE
	-an $buttonValue "right"
	
	-af $buttonValueAdd "top" 0
	-af $buttonValueAdd "bottom" 0
	-ac $buttonValueAdd "left" 0 $buttonValue
	-an $buttonValueAdd "right"
	
	-af $APvalueFloatFieldGE "top" 0
	-af $APvalueFloatFieldGE "bottom" 0
	-an $APvalueFloatFieldGE "right"
	-ac $APvalueFloatFieldGE "left" 0 $buttonValueAdd
	$form;
}



global proc APsetTimeFloatFieldCmd(float $val)
{
    if (`getModifiers` == 1)
    {
        $val*=-1;
    }
    keyframe -animation keys -r -o over -tc $val;
}

global proc APsetTimeFloatFieldAbsCmd(float $val)
{
    global string $APsetGlobalMoveModeGE;
    float $tmpVal[] = `keyframe -q -tc`;
    for ($time in $tmpVal)
    {
	if ($APsetGlobalMoveModeGE == "x")
	{    
	  if (catchQuiet(`keyframe -animation keys -a -o over -tc $val`))
	  {keyframe -animation keys -r -o over -tc ($time*$val);}
	}

	if ($APsetGlobalMoveModeGE == ":")
	{    
	  if (catchQuiet(`keyframe -animation keys -a -o over -tc $val`))
	  {keyframe -animation keys -r -o over -tc ($time/$val);}
	}

	if ($APsetGlobalMoveModeGE == "+")
	{    
	  if (catchQuiet(`keyframe -animation keys -a -o over -tc $val`))
	  {keyframe -animation keys -r -o over -tc ($time+$val);}
	}

	if ($APsetGlobalMoveModeGE == "-")
	{    
	  if (catchQuiet(`keyframe -animation keys -a -o over -tc $val`))
	  {keyframe -animation keys -r -o over -tc ($time-$val);}
	}
    }
}

global proc APsetValueFloatFieldCmd(float $val)
{
    //if (`getModifiers` == 1)
    //{
       // $val*=-1;
    //}
    //keyframe -animation keys -r -vc $val;
    global string $APsetGlobalMoveModeGE;
    float $tmpVal[] = `keyframe -q -vc`;
    float $tmpTime[] = `keyframe -q -tc`;
    int $i=0;
  //  for ($time in $tmpVal)
   // {
	if ($APsetGlobalMoveModeGE == "x")
	{    
	  if (catchQuiet(`keyframe -animation keys -a -o over -vc $val`))
	  {keyframe -animation keys -r -o over -vc ($val*=$val);}
	}

	if ($APsetGlobalMoveModeGE == ":")
	{    
	  if (catchQuiet(`keyframe -animation keys -a -o over -vc $val`))
	  {keyframe -animation keys -r -o over -vc ($val/=$val);}
	}

	if ($APsetGlobalMoveModeGE == "+")
	{    
	  if (catchQuiet(`keyframe -animation keys -a -o over -vc $val`))
	  {keyframe -animation keys -r -o over -vc ($val+=$val);}
	}

	if ($APsetGlobalMoveModeGE == "-")
	{    
	  if (catchQuiet(`keyframe -animation keys -a -o over -vc $val`))
	  {keyframe -animation keys -r -o over -vc ($val-=$val);}
	}
   // $i++;
   // }
}


global proc APsetValueFloatFieldAbsCmd(float $val)
{
    global string $APsetGlobalMoveModeGE;
    float $tmpVal[] = `keyframe -q -vc`;
    float $tmpTime[] = `keyframe -q -tc`;
    int $i=0;
    for ($time in $tmpVal)
    {
	if ($APsetGlobalMoveModeGE == "x")
	{    
	  if (catchQuiet(`keyframe -animation keys -a -o over -tc $val`))
	  {keyframe -time $tmpTime[$i] -r -o over -vc ($time*$val);}
	}

	if ($APsetGlobalMoveModeGE == ":")
	{    
	  if (catchQuiet(`keyframe -animation keys -a -o over -tc $val`))
	  {keyframe -time $tmpTime[$i] -r -o over -vc ($time/$val);}
	}

	if ($APsetGlobalMoveModeGE == "+")
	{    
	  if (catchQuiet(`keyframe -animation keys -a -o over -tc $val`))
	  {keyframe -time $tmpTime[$i] -r -o over -vc ($time+$val);}
	}

	if ($APsetGlobalMoveModeGE == "-")
	{    
	  if (catchQuiet(`keyframe -animation keys -a -o over -tc $val`))
	  {keyframe -time $tmpTime[$i] -r -o over -vc ($time-$val);}
	}
    $i++;
    }
    //string $selList[] = `selectionConnection -q -obj "keyframeList"`;
    //if (`size $selList`)
    //{
    //  keyframe -animation keys -absolute -valueChange $val;
    //  //keyTangent -itt flat -ott flat $selList;
    //}
}

global proc APupdateGEfloatFields()
{
global string $APvalueFloatFieldGE;
global string $APtimeFloatFieldGE;
floatField -e -ebg 0 -bgc 0.164706 0.164706 0.164706 $APtimeFloatFieldGE;
floatField -e -ebg 0 -bgc 0.164706 0.164706 0.164706 $APvalueFloatFieldGE;
if (size(`keyframe -q -sl`))
{
    float $vals[] = `keyframe -q -vc -sl`;
    float $times[] = `keyframe -q -tc -sl`;
    floatField -e -v $vals[`size $vals`-1] $APvalueFloatFieldGE;
    floatField -e -v $times[`size $times`-1] $APtimeFloatFieldGE;
    if(`size $vals`>1)
    {
        for ($val in $vals)
        {
            if ($vals[0] != $val)
                {floatField -e -ebg 1 -bgc 0.729 0.588 0.745  $APvalueFloatFieldGE;
                break;}
        }
    
    
    
        for ($time in $times)
        {
            if ($times[0] != $time)
                {floatField -e -ebg 1 -bgc 0.729 0.588 0.745  $APtimeFloatFieldGE;
                break;}
        }
    }
}
}

global proc APcopyPasteKeyWithTempOffset(float $offset)
{
  copyKey ;
  string $from[] = `keyframe -q -sl -n` ;
  string $selConn = `editor -q -selectionConnection graphEditor1OutlineEd`;
  string $curves[] = findAnimCurves($selConn);
  string $curv[] = stringArrayRemoveExact($from,$curves);
  string $cn[] = `listConnections   -p 1 $curv[0]`;

  pasteKey -option replace -copies 1 -connect 1 -timeOffset $offset -floatOffset 0 -valueOffset 0 -attribute (plugAttr($cn[0])) (plugNode($cn[0]));
}

