global string $APgraphAltIconPath;
global string $APgraphEditorAltPath;


global proc APreplaceGEiconBar()
{
	
  
	if(!`optionVar -ex APdoPreserveIn`)
	{optionVar -iv APdoPreserveIn 1;}
	if(!`optionVar -ex APdoPreserveOut`)
	{optionVar -iv APdoPreserveOut 1;}
	if(!`optionVar -ex APonlySelection`)
	{optionVar -iv APonlySelection 1;}
	if(!`optionVar -ex APkeepAutoTangentAlive`)
	{optionVar -iv APkeepAutoTangentAlive 0;}
	if(!`optionVar -ex APskipTangentsSmooth`)
	{optionVar -iv APskipTangentsSmooth 1;}
	
        global string $APgraphEditorAltPath;
        global string $APgraphAltIconPath;
	global string $APflow;
	if ($APflow == "")
	{
	  if (`flowLayout -ex $APflow`==0)
	  {
	    
	    string $altParent = `control -q -p graphEditor1OutlineEdForm`;
	    if (!`optionVar -ex "aTan_softness"`)
	    {optionVar -fv "aTan_softness" 0.0;}

	    string $Parent = `control -q -p $altParent`;
	    string $chil2[] = `formLayout -q -ca $Parent`;
	    string $chil[] = `frameLayout -q -ca $chil2[0]`;
	    string $chil3[] = `formLayout -q -ca $chil[0]`;
	    flowLayout -e -vis 0 $chil3[0];
	    $APflow =  `flowLayout -p $chil[0]`;
	    string $content[] = `flowLayout -q -ca $chil3[0]`;
	    formLayout -e 
	    -af $APflow "top" 0
	    -af $APflow "left" 0
	    -af $APflow "right" 0
	    -af $APflow "bottom" 0
	    $chil[0];
	    global string $APgraphCurve;
	    global string $APoutlinerPanel;
	    for ($button in $content)
	    {
	    //print(`objectTypeUI $button`+"\n");		
		 if ($button != "keyframeStats")
		 {
			    if ($button != "interpSeparator")
			    {			
			      if ($button != "frameAllButton" && $button != "frameRangeButton" && $button != "centerCurrentTimeButton")
			      {control -e -p $APflow $button;}
			    }
			    
			    if ($button == "interpSeparator")
			    {
				//button  -p $APflow -l "Auto Tangents" -bgc 0.89 0.43 0.47 -c "trdprty_tungsethTangent" -ann "Auto tangents" -w 90 -h 24;
				button  -p $APflow -l "Auto Tangents" -bgc 0.89 0.43 0.47 -c "APautoSmoothKeys" -ann "Auto tangents" -w 90 -h 24;
				string $ppm = `popupMenu -b 3`;
				//string $ppm2 = `popupMenu -b 2`;
				  popupMenu -e -pmc ("APbuidMenuSmooth("+"\""+$ppm+"\""+")") $ppm;
				  //popupMenu -e -pmc ("APbuidMenuLiveATOption("+"\""+$ppm2+"\""+")") $ppm2;
				    //string $col = `radioMenuItemCollection -p $ppm`;
				    //menuItem -p $ppm -l "- Smoothness -" -en 0;
				button -p $APflow -w 24 -bgc 0.5 0.69 0.87 -ann "Isolate Selected Curve(s)" -c ("global int $APisolateCurveActive; if(!$APisolateCurveActive){APisolateSelectedCurves("+"\""+$APoutlinerPanel+"\""+","+"\""+$APgraphCurve+"\""+",1);}") -l "[ i ]";
                button -p $APflow -w 24 -ann "copyPasteWithAnOffset" -l "CP" -c "APcopyPasteKeyWithTempOffset(1)";
			    }
		    }
		    else
		    {

			    //APbuildAltKeyStats();
			    control -e -p $APflow $button;
			    button -p $APflow -w 24 -ann "Align Selected Keys values on the Highest Key value of the Selection" -c "APgraphKeystoUpperBoundSwitcher()" -l "¯";
			    button -p $APflow -w 24 -ann "Align Selected Keys values on the Lowest Key value of the Selection" -c "APgraphKeystoLowerBoundSwitcher()" -l "_";
			    //button -p $APflow -w 24 -ann "Align Selected Keys values on the Average value of all Selected Keys" -c APsetKeyValToAverageBound -l "�";
			    button -p $APflow -w 24 -ann "Reset Selected Keys to their Default Values" -c APresetKeyToDefault -l "0";
			    button -p $APflow -w 24 -ann "Click = Globaly align selected Keys values on the First value of all Selected Keys\nShift+Click = Relative align selected Keys values on the First value of all Selected Keys" -c APgraphKeystoFirstSwitcher -l "x--";
			    button -p $APflow -w 24 -ann "Click = Globaly align selected Keys values on the Last value of all Selected Keys\nShift+Click = Relative align selected Keys values on the Last value of all Selected Keys" -c APgraphKeystoLastSwitcher -l "--x";
			    button -p $APflow -w 24 -ann "Click = Relative scale Down Keys values from the first value of all Selected Keys\nShift+Click = Relative scale Up Keys values from the first value of all Selected Keys" -c "APperCurveSetRelativeKeyScaleFromFirst(0)" -l ("x "+"\\");
			      string $ppmScaleFlow1 = `popupMenu`;
			      popupMenu -e -pmc ("APscaleKeyFromFlowPPM("+"\""+$ppmScaleFlow1+"\""+")") $ppmScaleFlow1;
			    button -p $APflow -w 24 -ann "Click = Relative scale Down Keys values from the last value of all Selected Keys\nShift+Click = Relative scale Up Keys values from the last value of all Selected Keys" -c "APperCurveSetRelativeKeyScaleFromFirst(1)" -l "/ x";
			      string $ppmScaleFlow2 = `popupMenu`;
			       popupMenu -e -pmc ("APscaleKeyFromFlowPPM("+"\""+$ppmScaleFlow2+"\""+")") $ppmScaleFlow2;
				
			    //button -p $APflow -w 30 -ann "Click = Move All Selected keys to Current Time\nShift+Click = Relative Move All Selected Keys to Current Time" -c "scaleKey -scaleSpecifiedKeys 1 -newStartTime `currentTime -q` -newStartFloat `currentTime -q` -newEndTime `currentTime -q` -newEndFloat `currentTime -q`; keyframe -a -o over -t `currentTime -q`;" -l " > | < ";
			    button -p $APflow -w 35 -ann "Relative Move All Selected Keys to Current Time ( Keep timing )" -c "APrelativeMoveFullKeySelection()";
			    iconTextButton -p $APflow -w 30 -ann "Reverse Animation of Selected Keys" -c "APreverseTiming" -bgc 0.365 0.365 0.365  -i "undo_s.png";
			    iconTextButton -p $APflow -h 23 -w 30 -ann "click = Reverse Values from first Selected Keys\shift+Click = Reverse Values from Last Selected Keys" -bgc 0.365 0.365 0.365 -c "APreverseValues" -rot -1.5708 -i "undo_s.png";
			    //button -p $APflow -w 24 -ann "Click = Relative scale Up Keys values from the first value of all Selected Keys" -c "APperCurveSetRelativeKeyScaleFromFirst(0.1)" -l ("+~");
			    iconTextButton -p $APflow -w 24 -visibility 0 -ann "Help" -c "APlaunchGrapEditorHelp" -bgc 0.365 0.365 0.365 -i "help.png"; //-bgc 0.65 0.93 0.65 
			
		            iconTextButton -p $APflow -w 23 -h 23  -ann "Apply Euler Filter On Selected Keys" -ua 1 -st "iconAndTextCentered" -l "Œ" -bgc 0.365 0.365 0.365 -c "APeulerFilterOnSelectedKeys()" -i ($APgraphAltIconPath+"euler.png") -hi ($APgraphAltIconPath+"euler_HI.png");
			    button -p $APflow -w 50 -ann "Noise Selected Keys" -c "APdoNoise(1,1,0.5)" -l "Noise"; //-bgc 0.65 0.93 0.65 
			    button -p $APflow -w 24 -ann "copyPasteWithAnOffset" -l "CP" -c "APcopyPasteKeyWithTempOffset(1)";
			    string $ppmm = `popupMenu -b 3`;
				menuItem -p $ppmm -cb `optionVar -q APdoPreserveIn` -c ("optionVar -iv APonlySelection (1-`optionVar -q APdoPreserveIn`)") -l "Preserve IN";
				menuItem -p $ppmm -cb `optionVar -q APdoPreserveOut` -c ("optionVar -iv APonlySelection (1-`optionVar -q APdoPreserveOut`)") -l "Preserve OUT";
				menuItem -p $ppmm -cb `optionVar -q APonlySelection` -c ("optionVar -iv APonlySelection (1-`optionVar -q APonlySelection`)") -l "On Selection Only";
			    //button -p $APflow -w 50 -ann "Smooth Selected Keys" -c APsmoothKeys -l "Smooth";
			      
			    
			    //iconTextButton -p $APflow  -style "iconOnly" -i "modifyStraighten" -ann "Align Selected Keys values on a slope drawn between the first and last key of the selection" -w 24 -h 24 -c APrebuildSlope -l "/";	
		    }
	    }
	  }
	}
}


global proc APrelativeMoveFullKeySelection()
{
  float $d[] = `keyframe -q -tc`;
  float $tc ;
  //print `getModifiers`;
  if(`getModifiers` == 0)
  {
     $tc = (`currentTime -q`-$d[0]);
    
  }
  
  if(`getModifiers` == 4)
  {
    float $times[] = `sort $d`;
    $tc = (`currentTime -q`-$times[`size $times`-1]);
    
  }
  catchQuiet(`keyframe -animation keys -o over -r -tc $tc`);
}

global proc APisolateSelectedCurves(string $editorName, string $curveEditor, int $mode)
{
	global string $APtmpCurrentSel[];
	global string $APgraphCurve;
	global string $SelectionfromEditor;
	global string $APemptySelectionfromEditor;
	global string $APpinedList[];
	global int $APisolateCurveActive;
	
	if($mode)
	{
	  $APgraphCurve = "graphEditor1GraphEd";
	  string $dff[] = `APlistSelectedCurves $APgraphCurve`;
	  string $dff2[] = `selectionConnection -q -obj "keyframeList"`;
	  selectionConnection -e -clear $SelectionfromEditor;
	  string $attr[];
	  string $tmp[];
	  clear $attr;
	  $APemptySelectionfromEditor = `selectionConnection`;
	  selectionConnection -e -clear $APemptySelectionfromEditor;
	  //string $pinlist[] = `outlinerEditor -q -pin $outLiner`;
	  outlinerEditor -e -mainListConnection $APemptySelectionfromEditor $editorName;
	  clear $APpinedList;
	  for ($curve in $dff2)
	  {
		  string $t[] = `listConnections -s 0 -d 1 -p 1 $curve`;
		  outlinerEditor -e -pin $t[0] $editorName;
		  evalDeferred("selectionConnection -e -select "+$t[0]+" "+"\""+$SelectionfromEditor+"\"");
		  $APpinedList[`size $APpinedList`] = $t[0];
	  }
	  string $parent = `outlinerEditor -q -p $editorName`;
	  string $children[] = `formLayout -q -ca $parent`;
	  $children = `columnLayout -q -ca $children[0]`;
	  $children = `formLayout -q -ca $children[0]`;
	  textField -e -ebg 1 -bgc 0.871 0.875 0.478 $children[1];
	  $APisolateCurveActive = 1;
	}
	else
	{
	  
	  APdefaultMayaIsolateCurve((1-$APisolateCurveActive));
	  $APisolateCurveActive = (1-$APisolateCurveActive);
	  //print $APisolateCurveActive;
	}
	//print "hello";
	//APtogglePinSelected ($editorName);

	//select -cl;
	//for ($curve in $dff2)
	//{
	//	string $t[] = `listConnections -s 0 -d 1 -p 1 $curve`;
		
	//}
	
	//selectionConnection -e -clear $APemptySelectionfromEditor;
	
	
	//animCurveEditor -e -af 1 $curveEditor;
	//animCurveEditor -e -af 0 $curveEditor;
	
	//evalDeferred("selectionAsFilter("+"\""+$editorName+"\""+", "+"\""+$curveEditor+"\""+")");
}

global proc APdefaultMayaIsolateCurve(int $active)
{
	eval(("isolateAnimCurve "+$active+" graphEditor1FromOutliner graphEditor1GraphEd"));
}

global proc string[] APlistSelectedCurves (string $editorName)
{
	return `animCurveEditor -q -cs graphEditor1GraphEd`;
}

