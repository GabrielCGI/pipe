	//showWindow;
}

global proc APprefilterGraphEditor(string $tx, string $APoutlinerPanel)
{
	if (!`itemFilterAttr -q -exists userAnimItemFilter`)
	{
			itemFilterAttr -hc 1 -k 1 -bs "APuserAnimFilter" userAnimItemFilter;
	}
	global string $userAttrFilter[];
	clear $userAttrFilter;
	translateFilter(1, $tx);
	rotateFilter(1, $tx);
	scaleFilter(1, $tx);
	userAttrFilter(1, $tx);
	$userAttrFilter = stringArrayRemoveDuplicates( $userAttrFilter );
	//print $userAttrFilter;
	outlinerEditor -e -attrFilter userAnimItemFilter -showConnected 1 $APoutlinerPanel;
}

global proc APpinAll (string $outLiner, int $mode)
{
  string $selectedChannels[] = `selectionConnection -q -obj "graphEditorList"`;
  string $animated[] = `listConnections -s 1 -d 0 -c 1 -p 0 -type "animCurve" $selectedChannels`;
  for ($chan in  $animated)
  {
    if ($mode)
    {outlinerEditor -e -pin $chan $outLiner;}
    else
    {outlinerEditor -e -unp $chan $outLiner;}
  }
}

global proc APresetAllpin (string $outLiner)
{
  global string $APpinedList[];
  for ($chan in  $APpinedList)
  {
    if (attributeExists(`plugAttr $chan`, `plugNode $chan`))
    {outlinerEditor -e -unp $chan $outLiner;}
  }
}

global proc APtogglePinSelected (string $outLiner)
{
  global string $SelectionfromEditor;
  string $selectedChannels[] = `selectionConnection -q -obj $SelectionfromEditor`;
  string $pinned[] = `outlinerEditor -q -pin $outLiner`;
  for ($chan in $selectedChannels)
  {
    //$chan = plugAttr($chan);
    if (stringArrayContains($chan , $pinned))
    {outlinerEditor -e -unp $chan $outLiner;}
    else
    {outlinerEditor -e -pin $chan $outLiner;}
   }

}

global proc APtogglePinInvert (string $outLiner)
{

}


global proc APtoggleShowPin(string $outLiner)
{
  outlinerEditor -e -spi (1-`outlinerEditor -q -spi $outLiner`) $outLiner;
  if (`optionVar -ex "APshowPinGE"`)
  {
    optionVar -iv "APshowPinGE" `outlinerEditor -q -spi $outLiner`;
  }
}

global proc string APbuildHyperPinRegExp()
{
  global string $SelectionfromEditor;
  string $conAttr[] = `listConnections -s 0 -d 1 -connections 1 $SelectionfromEditor`;
  int $r=0;
  string $finalstring ="";
  for ($df in $conAttr)
  {
    $finalstring += (plugAttr($conAttr[$r]));
    $r+=2;
    if ($r>(`size $conAttr`/2))
    {break;}
    $finalstring += "+";
  }
  return $finalstring;
}


global proc APisolateSelected2(string $editorName, string $curveEditor)
{
	global string $APgraphCurve;
	global string $SelectionfromEditor;
	$APgraphCurve = "graphEditor1GraphEd";
	string $dff[] = `APlistSelectedCurves $APgraphCurve`;
	string $dff2[] = `selectionConnection -q -obj "keyframeList"`;
	selectionConnection -e -clear $SelectionfromEditor;
	string $attr[];
	string $tmp[];
	clear $attr;
	for ($curv in $dff2)
	{
	 $tmp = `listConnections -s 0 -d 1 -c 0 -p 1 $curv`;
	 $attr[`size $attr`] = plugNode($tmp[0]);
	}
	//select $attr;
	for ($curve in $dff2)
	{
		string $t[] = `listConnections -s 0 -d 1 -p 1 $curve`;
		selectionConnection -e -select $t[0] $SelectionfromEditor;
	}
	animCurveEditor -e -af 1 $curveEditor;
	animCurveEditor -e -af 0 $curveEditor;
	
	//evalDeferred("selectionAsFilter("+"\""+$editorName+"\""+", "+"\""+$curveEditor+"\""+")");
}



global proc APisolateSelectedMaya(string $editorName, string $curveEditor)
{
  global int $APisolateCurveActive;
  global string $APgraphCurve;
  //print ("isolateAnimCurve true "+$editorName+" "+$APgraphCurve);
  	string $parent = `outlinerEditor -q -p $editorName`;
	string $children[] = `formLayout -q -ca $parent`;
	$children = `columnLayout -q -ca $children[0]`;
	$children = `formLayout -q -ca $children[0]`;
	textField -e -ebg 1 -bgc 0.871 0.875 0.478 $children[1];

  isolateAnimCurve (1-$APisolateCurveActive) graphEditor1FromOutliner $APgraphCurve; 
  $APisolateCurveActive = (1-$APisolateCurveActive);

}
global proc switchFilterType(int $mode)
{
  if (`optionVar -ex "APgraphQuickFilterMode"` && `optionVar -ex "APgraphTightFilterMode"`)
  {
    optionVar -iv "APgraphQuickFilterMode" $mode;
    //print ("set quickFilter to "+ `optionVar -q "APgraphQuickFilterMode"`+"\n");
    optionVar -iv "APgraphTightFilterMode" (1-$mode);
    //print ("set tightFilter to "+ `optionVar -q "APgraphTightFilterMode"`+"\n");
  }
}

global proc APreplaceOutliner()
{
   APreplaceOutlinerSwitch(1);
}

global proc APreplaceOutlinerSwitch(int $mode)
{
    global string $APgraphEditorAltPath;
    string $path = `whatIs "APreplaceOutliner"`;
    string $paths[] = stringToStringArray($path, " ");
    string $root = dirname($paths[`size $paths`-1]);
    $APgraphEditorAltPath = ($root+"/");

    string $AProotPath = (APstripPathLength($APgraphEditorAltPath , 1)+"/");
    //APverbosePrint($APgraphEditorAltPath);
    catchQuiet(APrecursiveSourcingSkip($APgraphEditorAltPath, "*.mel", "APgraphEditorAlt.mel"));
    
    string $tmps[] = stringToStringArray(`playblast -ae`,"|");
    string $panel = $tmps[`size $tmps`-1];
    if ($panel == "")
    {
      $panel = `getPanel -wf`;
    }
    if ($mode == 1 )
    {GraphEditor;}
    if ($mode == 2 )
    {scriptedPanel -e -rp $panel graphEditor1;}
    if (`iconTextCheckBox -exists "graphEditor1OutlineEdloadToggleButton"`)
    {iconTextCheckBox -e -enable 0 "graphEditor1OutlineEdloadToggleButton";}
    string $altParent = `control -q -p graphEditor1OutlineEdForm`;
    control -e -m 0 graphEditor1OutlineEdForm;
    global string $alternateED;
    $alternateED = `APgraphEditorAlt ($altParent)`;
    paneLayout -e -ps 1 25 100 -sp $alternateED 1 $altParent;


    string $Parent = `control -q -p $altParent`;
    string $chil2[] = `formLayout -q -ca $Parent`;
    string $chil[] = `frameLayout -q -ca $chil2[0]`;
    APgraphEditorCustomToolBar($chil[0]);
    
    //APreplaceGEiconBar;
    //evalDeferred("APreselectAll");

}

global proc APrebuidDefautSelectionConnection()
{
    //print "\nhello toto";
    if (!`control -q -ex graphEditor1OutlineEdForm`)
    {
      if (!`selectionConnection -q -ex graphEditor1FromOutliner`)
      {
	selectionConnection graphEditor1FromOutliner;
	outlinerEditor -e -mainListConnection "graphEditorList" -selectionConnection graphEditor1FromOutliner graphEditor1OutlineEd;
	animCurveEditor -e -mainListConnection "graphEditor1FromOutliner"  graphEditor1GraphEd;
      }
      if (`animCurveEditor -q -mainListConnection "graphEditor1GraphEd"` != "graphEditor1FromOutliner")
      {animCurveEditor -e -mainListConnection "graphEditor1FromOutliner"  graphEditor1GraphEd;}
    }
    else
    {
      global string $SelectionfromEditor;
      animCurveEditor -e -mainListConnection $SelectionfromEditor  graphEditor1GraphEd;
    }
    global string $APflow;
    $APflow = "";
}

global proc ifContainer()
{
  string $sel[] = `ls -sl`;
  global string $APoutlinerPanel;
  string $cont2="";
  $cont2 = `container -q -fc $sel`;
  if ($APoutlinerPanel != "")
  {
    if ($cont2!="")
    {outlinerEditor -e -hir 0 -sco 0 -scc 0 -expandConnections 1 $APoutlinerPanel;}
    else
    {outlinerEditor -e -hir 1 -sco 1 -scc 1 -expandConnections 0 $APoutlinerPanel;}
  }
}

global proc ifContainer2()
{
  string $sel[] = `ls -sl`;
  global string $APoutlinerPanel;
  outlinerEditor -e -hir 1 -sco 1 -expandConnections 0 $APoutlinerPanel;
  for ($obj in $sel)
  {
    if (`objectType $obj` == "container")
    {outlinerEditor -e -hir 0 -sco 0 -expandConnections 1 $APoutlinerPanel;
      break;}
  }
}


global proc removeOutliner()
{
    string $altParent = `control -q -p graphEditor1OutlineEdForm`;
    control -e -m 1 graphEditor1OutlineEdForm;
    global string $alternateED;
    if (`objExists $alternateED`)
    {deleteUI $alternateED; }
    paneLayout -e -sp graphEditor1OutlineEdForm 1 $altParent;
}

global proc updateFilterHistoryMenu(string $popupname, string $tx)
{
	string $optionVarContent[];
	global string $APoutlinerPanel;
	int $i = 0;
	if (`optionVar -ex "graphEditorFilterHistory"`)
	{
		popupMenu -e -dai $popupname;
		int $size = tokenizeList(`optionVar -q "graphEditorFilterHistory"`, $optionVarContent);
		//optionVar -sv "graphEditorFilterHistory" "";
		if ($size)
		{
			for ($item in $optionVarContent)
			{
				menuItem -l $item -p $popupname -c ("outlinerEditor -e -attrFilter 0 -showConnected true "+"\""+$APoutlinerPanel+"\""+"; matchFilter("+"\""+$item+"\""+"); outlinerEditor -e -attrFilter userAnimItemFilter -showConnected 0 "+"\""+$APoutlinerPanel+"\""+";textField -e -ebg 1 -bgc 0.871 0.875 0.478 "+"\""+$tx+"\""+"; textField -e -tx "+"\""+$item+"\""+" "+$tx);
				$i++;
				//optionVar -sv "graphEditorFilterHistory" (`optionVar -q "graphEditorFilterHistory"` + " " + $item );
				if($i>6)
				  break;
			}
			menuItem -p $popupname -d 1;
			//menuItem -l "Clear History" -c ("optionVar -sv "+"\""+"graphEditorFilterHistory"+"\""+"\""+""+"\"");
			menuItem -p $popupname -l "Clear History" -c ("optionVar -sv "+"\""+"graphEditorFilterHistory"+"\""+"\""+""+"\"");
		}
		
		//else
		//{
		//	menuItem -l "-----";
		//}
	}
}





global proc APselectionAsFilter(string $editorName, string $curveEditor)
{
	global string $userAttrFilter[];
	global string $APgraphCurve;
	$APgraphCurve = "graphEditor1GraphEd";
	outlinerEditor -e -attrFilter 0 $editorName;
	clear $userAttrFilter;
	//$curveEditor = "ultimGraph";
	string $dff[] = `APlistSelectedCurves $APgraphCurve`;
	string $attrsg[];
	clear $attrsg;
	for ($curve in $dff)
	{
	 string $t[] = `listConnections -p 1 $curve`;
	 $attrsg[`size $attrsg`] = $t[0];
	}
	string $tempd[];
	clear $tempd;
	for ($d in $attrsg)
	{
	 $tempd[`size $tempd`] = `plugAttr $d`;
	}
	string $shorterList[] = stringArrayRemoveDuplicates($tempd);
	$userAttrFilter = $shorterList;
	outlinerEditor -e -attrFilter userAnimItemFilter $editorName;
	//print $editorName;
	string $parent = `outlinerEditor -q -p $editorName`;
	string $children[] = `formLayout -q -ca $parent`;
	$children = `columnLayout -q -ca $children[0]`;
	$children = `formLayout -q -ca $children[0]`;
	textField -e -ebg 1 -bgc 0.871 0.875 0.478 $children[1];
}

global proc GEfilterQueue (string $buttonParent, string $APoutlinerPanel, string $text)
{
	global string $recompAttr;
	if (!`itemFilterAttr -q -exists userAnimItemFilter`)
	{
			//itemFilterAttr -hc 1 -k 1 -bs "APuserAnimFilter" userAnimItemFilter;
			itemFilterAttr -bs "APuserAnimFilter" userAnimItemFilter;
	}
	string $childArray[] =  `gridLayout -q -ca $buttonParent`;
	global string $userAttrFilter[];
	//if ((`iconTextCheckBox -q -v $childArray[2]`+`iconTextCheckBox -q -v $childArray[3]`+`iconTextCheckBox -q -v $childArray[4]`+`iconTextCheckBox -q -v $childArray[5]`) == 1)
	//{clear $userAttrFilter;}

	translateFilter(`button -q -ebg $childArray[2]`, $text );
	rotateFilter(`button -q -ebg $childArray[3]`, $text);
	scaleFilter(`button -q -ebg $childArray[4]`, $text);
	userAttrFilter(`button -q -ebg $childArray[5]`, $text);
	$userAttrFilter = stringArrayRemoveDuplicates( $userAttrFilter );
	//print $userAttrFilter;
	if ((`button -q -ebg $childArray[2]`+`button -q -ebg $childArray[3]`+`button -q -ebg $childArray[4]`+`button -q -ebg $childArray[5]`) == 0)
	{
		if (`textField -q -tx $text` != "" || $recompAttr != "")
		{
		  if (`textField -q -tx $text` != "")
		  {matchFilter(`textField -q -tx $text`);}
		  else
		  {matchFilter($recompAttr);}
		  outlinerEditor -e -attrFilter 0 -showConnected 1 $APoutlinerPanel;
		  outlinerEditor -e -attrFilter userAnimItemFilter -showConnected 1 $APoutlinerPanel;
		}
		else
		{outlinerEditor -e -attrFilter 0 -showConnected 0 $APoutlinerPanel;
		  outlinerEditor -e -attrFilter 0 -showConnected 1 $APoutlinerPanel;}
		
	}
	else
	{
	  outlinerEditor -e -attrFilter 0 -showConnected 1 $APoutlinerPanel;
	  outlinerEditor -e -attrFilter userAnimItemFilter -showConnected 1 $APoutlinerPanel;
	  
	}
	global string $SelectionfromEditor;
	string $dff3[] = `selectionConnection -q -obj "graphEditorList"`;
	//print $dff3;
	
	

	//global string $APgraphCurve;
	//$APgraphCurve = "graphEditor1GraphEd";
	//string $dff3[] = `selectionConnection -q -obj "animationList"`;
	//selectionConnection -e -clear "graphEditor1FromOutliner";
	//global string $SelectionfromEditor;
	//selectionConnection -e -clear $SelectionfromEditor;
	//for ($curve in $dff3)
	//{
	//	selectionConnection -e -select $curve $SelectionfromEditor;
	//}
}

