	//  optionVar -iv "APgraphQuickFilterMode" 1;
	//  optionVar -iv "APgraphTightFilterMode" 0;
	//}
		//string $hispop2 = `popupMenu -ctl 1 -p $tx -b 3`;
			//menuItem -rb `optionVar -q "APgraphQuickFilterMode"` -c "switchFilterType(1)" -l "Quick Filter";
			//menuItem -rb `optionVar -q "APgraphTightFilterMode"` -c "switchFilterType(0)" -l "Tight Filter";
			//setParent..;
	string $hispop = `popupMenu -p $tx -b 3`;
	popupMenu -e -pmc ("updateFilterHistoryMenu("+"\""+$hispop+"\""+","+"\""+$tx+"\""+")") $hispop;
	//outlinerEditor -e -sec ("synchroSelect3("+"\""+$tx+"\""+","+"\""+$row+"\""+","+"\""+"graphEditor1GraphEd"+"\""+")") $APoutlinerPanel;
	//animView -startTime (`playbackOptions -query -minTime` - 1) -endTime (`playbackOptions -query -maxTime` + 1) $curvEdit;
