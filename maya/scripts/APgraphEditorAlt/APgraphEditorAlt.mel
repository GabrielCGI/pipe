global proc string[] listSubNameFilter (string $curveEditor)
{
	global string $userAttrFilter[];
	global string $APgraphCurve;
	$APgraphCurve = "graphEditor1GraphEd";
	clear $userAttrFilter;
	//$curveEditor = "ultimGraph";
	string $dff[] = `APlistSelectedCurves $APgraphCurve`;
	string $attrsg[];
	clear $attrsg;
	for ($curve in $dff)
	{
	 string $t[] = `listConnections -p 1 $curve`;
	 $attrsg[`size $attrsg`] = $t[0];
	}
	string $tempd[];
	clear $tempd;
	for ($d in $attrsg)
	{
	 $tempd[`size $tempd`] = `plugAttr $d`;
	}
	
	string $shorterList[] = stringArrayRemoveDuplicates($tempd);
	return $shorterList;
}

global proc int isBigList(string $list[])
{
	string $buffer[];
	$numTokens = `tokenize $list[0] "_" $buffer`;
	return $numTokens;
}

