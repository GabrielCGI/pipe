	textField -e -ec ("outlinerEditor -e -attrFilter 0 -showConnected true "+"\""+$APoutlinerPanel+"\""+"; matchFilter(`textField -q -tx "+"\""+$tx+"\""+"`); GEfilterQueue ("+"\""+$APgraphEditGridLayout+"\""+","+"\""+$APoutlinerPanel+"\""+","+"\""+$tx+"\""+"); textField -e -ebg 1 -bgc 0.871 0.875 0.478 "+"\""+$tx+"\"") $tx;
	//	string $hispop = `popupMenu -p $tx -b 3`;
	//	popupMenu -e -pmc ("updateFilterHistoryMenu("+"\""+$hispop+"\""+")") $hispop;
	//	
	button -e -c ("global int $APisolateCurveActive; $APisolateCurveActive = 0; APresetTransformButtons ("+"\""+$APgraphEditGridLayout+"\""+"); textField -e -vis 1 "+"\""+$tx+"\""+"; flowLayout -e -vis 0 "+"\""+$row+"\""+";global string $recompAttr; $recompAttr = "+"\""+""+"\""+"; global string $userAttrFilter[]; clear $userAttrFilter; textField -e -tx "+"\""+""+"\" "+ $tx+"; GEfilterQueue ("+"\""+$APgraphEditGridLayout+"\""+","+"\""+$APoutlinerPanel+"\""+","+"\""+$tx+"\""+")"+"; APresetAllpin ("+"\""+$APoutlinerPanel+"\""+"); APreselectAll("+"\""+$tx+"\""+","+"\""+$APoutlinerPanel+"\""+"); textField -e -ebg 1 -bgc 0.165 0.165 0.165 " +"\""+$tx+"\""+"; outlinerEditor -e -attrFilter 0 -mainListConnection "+"\""+"graphEditorList"+"\""+" "+"\""+$APoutlinerPanel+"\"") $bt2;
	//outlinerEditor -e -sec ("fitCurentTime("+"\""+$curvEdit+"\""+")") $APoutlinerPanel;
	string $pe = `outlinerEditor -q -pnl $APoutlinerPanel`;
	//print ($tx+"\n");
	//outlinerPanel -e -pmp ("buildCustomGraphEditorPanel("+"\""+$APoutlinerPanel+"\""+")") $pe;
//	OutlinerEdMenuCommand outlinerEditor1;
	//print ("curve Editor: "+$curvEdit+"\n");
	//print ("outliner Editor: "+$APoutlinerPanel+"\n");
	//if (!`optionVar -ex "APgraphQuickFilterMode"` && !`optionVar -ex "APgraphTightFilterMode"`)
