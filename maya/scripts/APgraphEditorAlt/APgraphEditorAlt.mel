global proc APselectSameName (string $editorName, string $curveEditor)
{
	//$curveEditor = "ultimGraph";
	global string $APgraphCurve;
	$APgraphCurve = "graphEditor1GraphEd";
	//editor -edit -selectionConnection $fromEditor1 $APoutlinerPanel;
	string $sc = `editor -q -selectionConnection $editorName`;
	string $dff[] = `APlistSelectedCurves $APgraphCurve`;
	selectionConnection -e -clear $sc;
	for ($curve in $dff)
	{
		string $t[] = `listConnections -s 0 -d 1 -p 1 $curve`;
		$tempdd = `plugAttr $t[0]`;
		string $conAttr[] = `listConnections -s 1 -d 0 -connections 1 animationList`;
		for ($attr in $conAttr)
		{
			//selectionConnection -e -d $attr $sc;
			if (`gmatch $attr ("*."+$tempdd)`)
			{
			  selectionConnection -e -select $attr $sc;
			}
		}
	}
}

global proc selectFromAutoPin (string $editorName)
{
	//$curveEditor = "ultimGraph";
	global string $APgraphCurve;
	global string $userAttrFilter[];
	$APgraphCurve = "graphEditor1GraphEd";

	string $sel[] = `ls -sl`;
	if (`attributeExists "APuserFilter" $sel[0]`)
	{
	  string $filter[] = `listConnections ($sel[0]+".APuserFilter")`;
	  string $conAttr[];
	  clear $conAttr;
	  if(`size $filter`)
	  {
	    $conAttr = stringToStringArray(`getAttr  ($filter[0]+".regexp")`, "+");
	  }
	  //editor -edit -selectionConnection $fromEditor1 $APoutlinerPanel;
	  string $tempd[];
	  clear $tempd;
	  for ($attr in $conAttr)
	  {
	    $tempd[`size $tempd`] = $attr;
	  }
	  $userAttrFilter = stringArrayRemoveDuplicates($tempd);
	  outlinerEditor -e -as 0 -attrFilter userAnimItemFilter $editorName;
	}

}

global proc APaddDynamicFilter( string $regexp )
{
    string $list[] = `ls -sl`;
    for ($obj in $list)
    {
        if (!`attributeExists "APuserFilter" $obj`)
        {
	  addAttr -ln "APuserFilter"  -at long $obj;
	  string $node = `createNode network -ss -n "GraphEdUserFilter"`;
	  addAttr -ln "regexp"  -dt "string" $node;
	  connectAttr -f ($obj+".APuserFilter") ($node+".affectedBy[0]");
        }
        string $con[] = `listConnections ($obj+".APuserFilter")`;
        setAttr -e -type "string" ($con[0]+".regexp") $regexp;
    }
   // select $list;
}


global proc int APuserAnimFilter ( string $nodeName, string $attrName)
{
	
	int $good = 0;
	global string $userAttrFilter[];
	for ($attr in $userAttrFilter)
	{
		if ($attrName == $attr)
			$good = 1;
	}
	
	return $good;

}

