global proc string APstripPathLength(string $path , int $stripBackValue)
{
    string $tmpPath[] = stringToStringArray($path, "/");
    string $tmpPath2 = "";
    int $size = (`size $tmpPath`-$stripBackValue);
    int $i = 0;
    for ($chunk in $tmpPath)
    {
	if( $size > $i)
	{
	    $tmpPath2 += ("/"+$chunk);
	    
	}
	else
	    break;

	$i+=1;
    }
    
    return $tmpPath2;
}

global proc APrecursiveSourcingSkip(string $scriptPath, string $ext, string $toSkip)
{
	string $files[] = `getFileList -fld ( $scriptPath +"/")`;
	//waitCursor -state on;

	if ( size($files) )
		{
			string	$file;
			string	$tokens[];
			
			for ($file in $files)
			{

				$file = ($scriptPath + $file);
				
				if ( `gmatch $file $ext` && !`gmatch $file ("*"+$toSkip)`)
				{
					//print ("\nje source " + $file);
					int $result = catchQuiet(`evalDeferred("source \""+$file+"\"")`);
				}
	
				//	Parse sub-directory
				if ( `filetest -d $file` )
					APrecursiveSourcing( ($file +"/"), $ext );
			}
		}
		//waitCursor -state off;
}


global proc string APgraphEditorAlt(string $parent)
