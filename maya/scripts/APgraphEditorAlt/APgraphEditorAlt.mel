global proc string APsourcePathFromMasterProc(string $masterProc)
{
    
    string $path = `whatIs $masterProc`;
    string $paths[] = stringToStringArray($path, " ");
    string $root = dirname($paths[4]);
    //source ($root+"/APutils.mel");
    //APrecursiveSourcing($root, "*.mel");
    string $strippedPath = ($root+"/");
    return $strippedPath;
}


