	button -e -c ("pushTransform("+"\""+$tx+"\""+","+"\""+$translateFilterButton+"\""+","+"\""+$APgraphEditGridLayout+"\""+"); GEfilterQueue ("+"\""+$APgraphEditGridLayout+"\""+","+"\""+$APoutlinerPanel+"\""+","+"\""+$tx+"\""+")") $translateFilterButton;
	button -e -c ("pushTransform("+"\""+$tx+"\""+","+"\""+$rotateFilterButton+"\""+","+"\""+$APgraphEditGridLayout+"\""+"); GEfilterQueue ("+"\""+$APgraphEditGridLayout+"\""+","+"\""+$APoutlinerPanel+"\""+","+"\""+$tx+"\""+")") $rotateFilterButton;
	button -e -c ("pushTransform("+"\""+$tx+"\""+","+"\""+$scaleFilterButton+"\""+","+"\""+$APgraphEditGridLayout+"\""+"); GEfilterQueue ("+"\""+$APgraphEditGridLayout+"\""+","+"\""+$APoutlinerPanel+"\""+","+"\""+$tx+"\""+")") $scaleFilterButton;
