global proc synchroSelect3 (string $text, string $row, string $curveEditor)
{
  string $dff[] = `APlistSelectedCurves $curveEditor`;
//print $dff;
global string $APoutlinerPanel;
  if (`size $dff`==1) 
  { 
    string $attrs[] = `listConnections -s 0 -d 1 -p 1 ($dff[0]+".output")`;
    
    string $tmp = `plugAttr $attrs[0]`;
    //print $tmp;
    string $node = `plugNode $attrs[0]`;
    string $buffer[];
    string $attr = `attributeQuery -node $node -nn $tmp`;
    //print $attr;
    $numTokens = `tokenize $tmp "_" $buffer`;
    int $columnIndex=1;
    if ($numTokens > 1)
    {
      //print $numTokens;
      //flowLayout -e -nc `size $buffer` $row;
      string $children[] = `flowLayout -q -ca $row`;
      textField -e -vis 0 $text;
      //print $children;
      for ($tmp in $children)	
      {
	deleteUI $tmp;
	//print "je passe";
      }
      
      for ($attrPart in $buffer)	
      {
	  
	  //string $low = tolower($attrPart);
	  //print $attrPart;
	  string $button = `button -p $row -l $attrPart`;
	  button -e -c ("pushColor("+"\""+$text+"\""+","+"\""+$button+"\""+","+"\""+$row+"\""+")")  $button;
	  //flowLayout -e  -columnWidth $columnIndex (`size $attrPart`*9) $row;
	  $columnIndex++;
      }
      flowLayout -e -vis 1 $row;
    }
    else
    {
      flowLayout -e -vis 0 $row;
      textField -e  -vis 1 $text;
    }
    //outlinerEditor -e -as 0 $APoutlinerPanel;
  }

}

