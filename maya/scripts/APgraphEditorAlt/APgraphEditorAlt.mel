global proc pushTransform (string $tx, string $button, string $row)
{

    global string $APoutlinerPanel;
    global string $APgraphEditGridLayout;
    global string $recompAttr;
    string $children[] = `gridLayout -q -ca $row`;
    string $child;
    string $path;
    string $buffer[];
    int $numTokens = `tokenize $button "|" $buffer`;
       int $i =0;
       string $d;
      // print $buffer;
 
    for ($d in $buffer)
    {
        if ($i==($numTokens-1))
        {break;}        
        $path+= ($d+"|");
        $i++;

    }

    int $multiSel = 0;

    if (`getModifiers` != 1 && `getModifiers` != 4)
    {
      for ($child in $children)
      {
	if (`objectTypeUI $child` == "button")
	{$multiSel += `button -q -ebg $child`;}
      }
      //print ("multiSel= "+$multiSel+"\n");
      for ($child in $children)
      {
	  //print (($path+$child) +" "+$button+"\n");
	  if (`objectTypeUI $child` == "button")
	  {
	    if (($path+$child) == $button)
	    {

	      if ($multiSel == 1 || $multiSel == 0)
	      {
		if (!`button -q -ebg $button`)
		{
		  button -e -ebg 1 -bgc 0.871 0.875 0.478 $button;
		  textField -e -ebg 1 -bgc 0.871 0.875 0.478 $tx;
		}
		else
		{
		  button -e -ebg 0 -bgc 0.392 0.392 0.392 $button;
		  textField -e -ebg 1 -bgc 0.165 0.165 0.165 $tx;
		}
	      }
	      else
	      {
		button -e -ebg 1 -bgc 0.871 0.875 0.478 $button;
		textField -e -ebg 1 -bgc 0.871 0.875 0.478 $tx;
	      }
  

	    }
	    else
	    {
	      button -e -ebg 0 -bgc 0.392 0.392 0.392 $child;
	    }
	  }
      }
    }
    else
    {
      if (`objectTypeUI $button` == "button")
      {
	if (`button -q -ebg $button` == 1)
	{
	  button -e -ebg 0 -bgc 0.392 0.392 0.392 $button;
	  textField -e -ebg 1 -bgc 0.165 0.165 0.165 $tx;
	}
	else 
	{
	  button -e -ebg 1 -bgc 0.871 0.875 0.478 $button;
	  textField -e -ebg 1 -bgc 0.871 0.875 0.478 $tx;
	}
      }
      //APbuildRegExpFromButton($children);
    }
   //outlinerEditor -e -attrFilter 0 -showConnected true -showAnimCurvesOnly true $APoutlinerPanel;
    //print `button -q -l $button`;
    //matchFilter(`button -q -l $button`);
    //GEfilterQueue ($APgraphEditGridLayout,$APoutlinerPanel,$tx);
   // print $recompAttr;

}


global proc pushColor(string $tx, string $button, string $row)
{

    global string $APoutlinerPanel;
    global string $APgraphEditGridLayout;
    global string $recompAttr;
    string $children[] = `flowLayout -q -ca $row`;
    string $child;
    string $path;
    string $buffer[];
    int $numTokens = `tokenize $button "|" $buffer`;
       int $i =0;
       string $d;
      // print $buffer;
 
    for ($d in $buffer)
    {
        if ($i==($numTokens-1))
        {break;}        
        $path+= ($d+"|");
        $i++;

    }
    if (`getModifiers` != 1 && `getModifiers` != 4)
    {
      for ($child in $children)
      {
	  //print (($path+$child) +" "+$button+"\n");      
	  if (($path+$child) != $button)
	  {
	    button -e -ebg 0 -bgc 0.392 0.392 0.392 $child;
	  }
	  else
	  {
	    if (`button -q -ebg $button` == 0)
	    {
	      button -e -ebg 1 -bgc 0.871 0.875 0.478 $button;
	    }
	    else
	    {button -e -ebg 0 -bgc 0.392 0.392 0.392 $button;}
	    int $index = APgetStringIndex(`button -q -l $button`, $children);
	    //print $index;
	    if ($index == 0)
	    {$recompAttr = (`button -q -l $button`+"*");}
	    if ($index == (`size $children`-1))
	    {$recompAttr = ("*"+`button -q -l $button`);}
	    if ($index != 0 && $index != (`size $children`-1))
	    {$recompAttr = `button -q -l $button`;}
	  }
      }
    }
    else
    {
      if (`button -q -ebg $button` == 1)
      {
	button -e -ebg 0 -bgc 0.392 0.392 0.392 $button;
      }
      else 
      {button -e -ebg 1 -bgc 0.871 0.875 0.478 $button;}
      APbuildRegExpFromButton($children);
    }
   outlinerEditor -e -attrFilter 0 -showConnected true -showAnimCurvesOnly true $APoutlinerPanel;
    //print `button -q -l $button`;
    matchFilter(`button -q -l $button`);
    GEfilterQueue ($APgraphEditGridLayout,$APoutlinerPanel,$tx);
    textField -e -ebg 1 -bgc 0.871 0.875 0.478 $tx;
    //print $recompAttr;

}

global proc APbuildRegExpFromButton (string $array[])
{
  global string $recompAttr;
  $recompAttr = "";
  int $index = 0;
  int $index2 = 0;
  for ($child in $array)
  {
      if (`button -q -ebg $child` == 1)
      {
	if ($index==$index2)
	{
	  $recompAttr += `button -q -l $child`+"_";
	  $index2++;
	}
	else
	{
	  $recompAttr += ("*"+`button -q -l $child`+"*");
	  $index2 = $index;
	}
      }
      $index++;
  }
}

global proc int APgetStringIndex(string $stringToFind, string $array[])
{
  int $index = 0;
  for ($child in $array)
  {
    if (`button -q -l $child`== $stringToFind)
    {break;}
    $index++;
  }
  return $index;
}


global proc synchroSelect (string $APoutlinerPanel, string $curveEditor)
{
  if (size(`ls -sl`)>1) 
  { 
    if (`optionVar -ex autoSyncSelGE`)
    {
      if (`optionVar -q autoSyncSelGE`==1)
      {
	evalDeferred ("selectSameName ("+"\""+$APoutlinerPanel+"\""+","+"\""+$curveEditor+"\""+")");
	//selectSameName ($APoutlinerPanel,$curveEditor);
      }
    }
  }

  if (size(`ls -sl`)==1)
  {
    if (`optionVar -ex autoSyncSelGE`)
    {
      if (`optionVar -q autoSyncSelGE`==1)
      {
	selectFromAutoPin($APoutlinerPanel);
      }
    }
  }
  else
  {	
	outlinerEditor -e -attrFilter 0 $APoutlinerPanel;
	global string $userAttrFilter[];
	clear $userAttrFilter;
  }
}



global proc matchFilter(string $regex)
{
	global string $userAttrFilter[];
	int $smart = `optionVar -q "APgraphQuickFilterMode"`;
	//print ("smart ="+$smart+"\n");
	clear $userAttrFilter;
	string $history;
	//clear $history;
	string $seltmp[] = `ls -sl`;
	//python("import gmatch as gm");
	//string $selString = stringArrayToString(`listAttr -u -k`, " ");
	if (`size  $seltmp`)
	{
	  string $sel[] = `listAttr -u -k $seltmp`;
	  $sel = stringArrayRemoveDuplicates($sel);
	  //string $userAttrFilterTmp[] = python("gm.gmatch('"+$regex+"','"+$selString+"')");
	  //string $userAttrFilter[];
	  //$userAttrFilter = stringArrayRemoveDuplicates($userAttrFilterTmp);
	  if (`size $sel`)
	  {
		  //string $sel[] = `listAttr -u -k $seltmp`;
		  for ($attr in $sel)
		  {
			  
			  //print ($attr+"\n"+$regex+"\n");
			  if (`gmatch $attr ("*"+$regex+"*")`)
			  {
				  //string $buffer[];
				 // $numTokens = `tokenize $regex "+" $buffer`;
				 // for ($attrs in $buffer)
				 // {
				//	  if (`gmatch $attr ("*"+$attrs+"*")`)
				//	  {$userAttrFilter[`size $userAttrFilter`] = $attr;}
				  //}
				  $userAttrFilter[`size $userAttrFilter`] = $attr;
			  }
			  else
			  {
				  //print ($attr+"\n");
				  if (`isValidObjectName($regex)`)
				  {
				    python("import re");
				    python("m = re.search('"+$regex+"', '"+$attr+"', re.IGNORECASE)");
				    int $result = python("bool(m)");
				    //print ("je passe en Smart\n");
				    if ($result)
				    {$userAttrFilter[`size $userAttrFilter`] = $attr;}
				  }
				  else
				  {
				    if (`gmatch $attr $regex`)
				    {$userAttrFilter[`size $userAttrFilter`] = $attr;}
				  }
			  }
		  }
	  }
	  string $optionVarContent[];
	  if (`optionVar -ex "graphEditorFilterHistory"`)
	  {
	    $history = `optionVar -q "graphEditorFilterHistory"`;
	    tokenizeList($history, $optionVarContent);
	  }
	  int $i = 0;
	  if (`size $optionVarContent`== 0)
	  {optionVar -sv "graphEditorFilterHistory" ( $regex+ " " + $history );}
	  else
	  {
	    for ($r in $optionVarContent)
	    {
		    if (`gmatch $history ("*"+$regex+"*")`)
		    { break;}
		    else
		    {optionVar -sv "graphEditorFilterHistory" ( $regex+ " " + $history );}
		    if($i>6)
		    {break;}
		    
	    }
	  }
	}
}

global proc translateFilter(int $clear,string $text)
{
	global string $userAttrFilter[];
	//if ($clear == 0)
	//{
	//	clear $userAttrFilter;
	//}
	string $regex = `textField -q -tx $text`;
	string $sel[] = `ls -sl`;
	if (`size $sel`)
	{
		string $sel[] = `listAttr -se -u -k -v`;
		for ($attr in $sel)
		{
			if (`gmatch $attr ("translate*"+$regex+"*")`)
			{
				//$userAttrFilter[`size $userAttrFilter`] = $attr;
				if ($clear==1)
				{$userAttrFilter[`size $userAttrFilter`] = $attr;}
				else
				{$userAttrFilter = stringArrayRemove({$attr}, $userAttrFilter);}
			}
		}
	}
	//print $userAttrFilter;
}

