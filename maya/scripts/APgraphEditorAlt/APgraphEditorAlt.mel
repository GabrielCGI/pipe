				{$userAttrFilter[`size $userAttrFilter`] = $attr;}
				else
				{$userAttrFilter = stringArrayRemove({$attr}, $userAttrFilter);}
			}
		}
	}
	//print $userAttrFilter;
}

global proc scaleFilter(int $clear, string $text)
{
	global string $userAttrFilter[];
	string $regex = `textField -q -tx $text`;
	string $sel[] = `ls -sl`;
	if (`size $sel`)
	{
		string $sel[] = `listAttr -se -u -k -v`;
		for ($attr in $sel)
		{
			if (`gmatch $attr ("scale*"+$regex+"*")`)
			{
				if ($clear==1)
				{$userAttrFilter[`size $userAttrFilter`] = $attr;}
				else
				{$userAttrFilter = stringArrayRemove({$attr}, $userAttrFilter);}
			}
		}
	}
	//print $userAttrFilter;
}

global proc userAttrFilter(int $clear, string $text)
{
	global string $userAttrFilter[];
	string $sel[] = `ls -sl`;
	string $regex = `textField -q -tx $text`;
	if (`size $sel`)
	{
		string $sel[] = `listAttr -se -k -u -v -ud`;
		//string $sel[] = `listAttr -cb -u -v -ud`;
		for ($attr in $sel)
		{
				if ($regex != "")
				{
				  if (`gmatch $attr ("*"+$regex+"*")`)
				  {
				    if ($clear==1)
				    {$userAttrFilter[`size $userAttrFilter`] = $attr;}
				    else
				    {$userAttrFilter = stringArrayRemove({$attr}, $userAttrFilter);}
				  }
				}
				else
				{
				  if ($clear==1)
				  {$userAttrFilter[`size $userAttrFilter`] = $attr;}
				  else
				  {$userAttrFilter = stringArrayRemove({$attr}, $userAttrFilter);}
				}
		}
	}
	//print $userAttrFilter;
}

global proc APrecursiveSourcing(string $scriptPath, string $ext)
{
	string $files[] = `getFileList -fld ( $scriptPath +"/") -fs $ext`;
	//waitCursor -state on;
	//print $files;
        //print ("\n\n");
        int $fileId2;
        string $exampleFileName = ( `internalVar -userTmpDir` + "log.txt" );
	$fileId2=`fopen $exampleFileName "a"`;
	if ( size($files) )
	{
		string	$file;
		string	$tokens[];
		
		for ($file in $files)
		{

			$file = ($scriptPath +"/"+ $file);
			//print ($file+"\n");
			if ( !`filetest -d $file` )
			{
			  //if ( `gmatch $file $ext` )
			  //{
				  
				  //int $result = catchQuiet(`eval("source \""+$file+"\"")`);
				  
				 
				  //
				  //
				  print ("Sourcing ---> "+basename( $file, ".mel" )+"\n");
				  fprint $fileId2 ("Sourcing ---> "+basename( $file, ".mel" )+"\n");
				  int $result = catchQuiet(evalDeferred("source \""+$file+"\""));
			          
				  if ($result ==  1 )
				  {
					  print ("Failed ---> "+basename( $file, ".mel" )+"\n");
					  fprint $fileId2 ("Failed ---> "+basename( $file, ".mel" )+"\n");
				  }
				  
			  //}
			 }
			else
			{ APrecursiveSourcing( $file , $ext ); }
		}
	}
	fclose $fileId2;
	//waitCursor -state off;
}

