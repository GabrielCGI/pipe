        -image1 "R:/pipeline/pipe/maya/shelfs/2026/ICONS/anim/Macdo_icon.jpg" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\nfrom functools import partial\n#-------------------------------------------------\n#---Functions ------\n#-----ARM IK FK Matcher--------------------\n###---Zero channels values for selected Transforms for list of objects\ndef ZeroTransforms(objs,Typs,axs):\n    for o in objs:\n        if Typs[0]==1:\n            for x in axs:\n                if cmds.objExists(o+\".t\"+x)==1:\n                    cmds.setAttr(o+\".t\"+x,0)\n                    #print (\"we are zroing out the Transalations and the current Axis is ...\"+str(x) )\n        ##-------------------------\n        if Typs[1]==1:\n            for x in axs:\n                if cmds.objExists(o+\".r\"+x)==1:\n                    cmds.setAttr(o+\".r\"+x,0)\n        ##-------------------------\n        if Typs[2]==1:\n            for x in axs:\n                if cmds.objExists(o+\".s\"+x)==1:\n                    cmds.setAttr(o+\".s\"+x,1)\n#--------------------------------------------------------\n#---Get the current NameSpaces\ndef GetCurNamespaces(*args):\n    Items = cmds.optionMenu(\"ATNameSpacesOptnMenu\", q=True, itemListLong=True)\n    if Items != None:\n        for m in Items:\n            cmds.deleteUI(m)\n    #-----------------------------------\n    AllNS=[]\n    namespaces = cmds.namespaceInfo(lon=True)\n    for u in namespaces:\n        if u !=\"UI\":\n          if u !=\"shared\":\n              if u not in AllNS:\n                  print(u)\n                  AllNS.append(u)\n    #------------------------------------\n    if len(AllNS)>0:\n       for o in AllNS:\n            cmds.menuItem(l=o, p=\"ATNameSpacesOptnMenu\")\n    #-------------------------------------------------------------\n\n#----Get and list all existing characters in the scene\ndef GetChars(*args):\n    Items = cmds.optionMenu(\"ATCharactersOptnMenu\", q=True, itemListLong=True)\n    if Items != None:\n        for m in Items:\n            cmds.deleteUI(m)\n    #-----------------------------------\n    #---we check first in Arms Module .....\n    searchGrps = cmds.ls()\n    CharLst=[]\n    for u in searchGrps:\n        if cmds.objExists(u + \".MainName\") == True:\n            Name = cmds.getAttr(u + \".MainName\")\n            if Name not in CharLst:\n               CharLst.append(Name)\n    #--------------------------------------\n    if len(CharLst)>0:\n        for o in CharLst:\n            cmds.menuItem(l=o, p=\"ATCharactersOptnMenu\")\n    #--------------------------------------------------------\n    #--------------------------------------------------\n#---------------------------------------------\ndef ArmIKFK_Matcher(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Arm=cmds.textField(\"ATArmTypTx\", q=1, tx=1)\n    #---------------------------------------------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Arm+\"_\"+Index\n    AttrCtrl=Title+\"_Attr_Ctrl\"\n    #--------\n    IK=Title+\"_IK_Main_Ctrl\"\n    IKOffset=Title+\"_IK_Main_Root_Ctrl\"\n    MidRot=Title+\"_IK_MidRot_Ctrl\"\n    PV=Title+\"_IK_PV_Ctrl\"\n    TipRot=Title+\"_IK_TipRot_Ctrl\"\n    #-------------------------------------------\n    IKCtrls=[IKOffset,IK,TipRot,MidRot,PV]\n    #-------------------------------------------\n    FKUpArm=Title+\"_UpArm_FK_Ctrl\"\n    FKForeArm=Title+\"_ForeArm_FK_Ctrl\"\n    FKHandA=Title+\"_HandA_FK_Ctrl\"\n    FKHandB=Title+\"_HandB_FK_Ctrl\"\n    #--------------------------------------------\n    FKUpArmOffset=Title+\"_UpArm_FK_Offset_Ctrl\"\n    FKForeArmOffset=Title+\"_ForeArm_FK_Offset_Ctrl\"\n    FKHandAOffset=Title+\"_HandA_FK_Offset_Ctrl\"\n    FKHandBOffset=Title+\"_HandB_FK_Offset_Ctrl\"\n    #--------------------------------------------\n    FKOffsets=[FKUpArmOffset,FKForeArmOffset,FKHandAOffset,FKHandBOffset]\n    #----------------------------------------\n    #ZeroTransforms(FKOffsets,[1,1,0],[\"x\",\"y\",\"z\"])\n    #----------------------------------------------------\n    Attrs=[AttrCtrl+\".Roll\",AttrCtrl+\".Banking\",AttrCtrl+\".TipRotate\",AttrCtrl+\".MidRotate\",AttrCtrl+\".HeelRotate\"]\n    for u in Attrs:\n        if cmds.objExists(u)==True:\n           cmds.setAttr(u,0)\n    #---------------------------------------------------\n    for u in IKCtrls:\n        if cmds.objExists(u)==True:\n           cmds.matchTransform(u,u+\"_Dock_Loc\")\n    #--------------------------------------------------\n    if cmds.objExists(AttrCtrl+\".IK_FK\")==True:\n       cmds.setAttr(AttrCtrl+\".IK_FK\",0)\n    #------------------------------------------------------\n#-------------------------------------------------\ndef ArmFKIK_Matcher(Side,*args):\n    # --------------------------------------------------\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Arm=cmds.textField(\"ATArmTypTx\", q=1, tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Arm+\"_\"+Index\n    AttrCtrl=Title+\"_Attr_Ctrl\"\n    # --------\n    UpArmIK = Title + \"_UpArm_IK_Jnt\"\n    ForeArmIK = Title + \"_ForeArm_IK_Jnt\"\n    HandAIK = Title + \"_HandA_IK_Jnt\"\n    HandBIK = Title + \"_HandB_IK_Jnt\"\n    # -------------------------------------------\n    IKJnts = [UpArmIK, ForeArmIK, HandAIK, HandBIK]\n    # -------------------------------------------\n    FKUpArm = Title + \"_UpArm_FK_Ctrl\"\n    FKForeArm = Title + \"_ForeArm_FK_Ctrl\"\n    FKHandA = Title + \"_HandA_FK_Ctrl\"\n    FKHandB = Title + \"_HandB_FK_Ctrl\"\n    FKCtrls = [FKUpArm, FKForeArm, FKHandA, FKHandB]\n    # --------------------------------------------\n    FKUpArmOffset = Title + \"_UpArm_FK_Offset_Ctrl\"\n    FKForeArmOffset = Title + \"_ForeArm_FK_Offset_Ctrl\"\n    FKHandAOffset = Title + \"_HandA_FK_Offset_Ctrl\"\n    FKHandBOffset = Title + \"_HandB_FK_Offset_Ctrl\"\n    # --------------------------------------------\n    FKOffsets = [FKUpArmOffset, FKForeArmOffset, FKHandAOffset, FKHandBOffset]\n    # ----------------------------------------\n    ZeroTransforms(FKOffsets, [1, 1, 0], [\"x\", \"y\", \"z\"])\n    # ----------------------------------------------------\n    Attrs = [AttrCtrl + \".Roll\", AttrCtrl + \".Banking\", AttrCtrl + \".TipRotate\", AttrCtrl + \".MidRotate\",\n             AttrCtrl + \".HeelRotate\"]\n    for u in Attrs:\n        if cmds.objExists(u)==True:\n           cmds.setAttr(u, 0)\n    # ---------------------------------------------------\n    for u in range(0, len(FKCtrls)):\n        if cmds.objExists(FKCtrls[u])==True:\n           if cmds.objExists(IKJnts[u])==True:\n              cmds.matchTransform(FKCtrls[u], IKJnts[u])\n    if cmds.objExists(AttrCtrl + \".IK_FK\")==True:\n       cmds.setAttr(AttrCtrl + \".IK_FK\", 10)\n    # ------------------------------------------------------\n#--------------------------------------------------\ndef ArmMirror(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Arm=cmds.textField(\"ATArmTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n        OppSide=LtSide\n    else:\n        Side=LtSide\n        OppSide=RtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Arm+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n        opp = u.replace(\"_\"+Side+\"_\",\"_\"+OppSide+\"_\")\n        try:\n            for Att in range(0, len(Attrs)):\n                val = cmds.getAttr(u + \".\" + Attrs[Att])\n                cmds.setAttr(opp + \".\" + Attrs[Att], val)\n        except:\n            print(\"\")\n#--------------------------------------------------\n#--------------------------------------------------\ndef ArmFlip(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Arm=cmds.textField(\"ATArmTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n        OppSide=LtSide\n    else:\n        Side=LtSide\n        OppSide=RtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Arm+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n        opp = u.replace(\"_\"+Side+\"_\",\"_\"+OppSide+\"_\")\n        try:\n            for Att in range(0,len(Attrs)):\n                val =cmds.getAttr(u + \".\" + Attrs[Att])\n                valB=cmds.getAttr(opp + \".\" + Attrs[Att])\n                cmds.setAttr(opp + \".\" + Attrs[Att], val)\n                cmds.setAttr(u + \".\" + Attrs[Att], valB)\n        except:\n            print(\"\")\n#--------------------------------------------------------------------\ndef ArmReset(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Arm=cmds.textField(\"ATArmTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Arm+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n        try:\n            for Att in range(0, len(Attrs)):\n                val = cmds.attributeQuery(Attrs[Att],node=u,ld=True)\n                cmds.setAttr(u + \".\" + Attrs[Att], val[0])\n        except:\n            print(\"\")\n#--------------------------------------------\ndef ArmKey(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Arm=cmds.textField(\"ATArmTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Arm+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        cmds.setKeyframe(u)\n#------------------------------------\ndef ArmSelect(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Arm=cmds.textField(\"ATArmTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Arm+\"_\"+Index\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        cmds.select(u,add=1)\n#---------------\n#--------------------------------------------\ndef ArmDelKey(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Arm=cmds.textField(\"ATArmTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Arm+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n         cmds.cutKey(u, cl=True)\n#---------------------------------------------------\n#---------------------------------------------------\n#-----Leg Part\n#--------------------------------------------\ndef LegIKFK_Matcher(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Leg=cmds.textField(\"ATLegTypTx\", q=1, tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Leg+\"_\"+Index\n    AttrCtrl=Title+\"_Attr_Ctrl\"\n    #--------\n    UplegIK=Title+\"_IK_UpLeg_Ctrl\"\n    IK=Title+\"_IK_Main_Ctrl\"\n    IKOffset=Title+\"_IK_Main_Root_Ctrl\"\n    MidRot=Title+\"_IK_MidRot_Ctrl\"\n    ToeRot=Title+\"_IK_ToeRot_Ctrl\"\n    PV=Title+\"_IK_PV_Ctrl\"\n    TipRot=Title+\"_IK_TipRot_Ctrl\"\n    #-------------------------------------------\n    IKCtrls=[UplegIK,IKOffset,IK,TipRot,MidRot,ToeRot,PV]\n    #-------------------------------------------\n    FKCtrls=[]\n    FKUpArm=Title+\"_UpLeg_FK_Ctrl\"  ;FKCtrls.append(FKUpArm)\n    FKForeArm=Title+\"_Knee_FK_Ctrl\" ;FKCtrls.append(FKForeArm)\n    FKFeet=Title+\"_Feet_FK_Ctrl\"    ;FKCtrls.append(FKFeet)\n    #-------\n    FKHandA=\"\"\n    if cmds.objExists(Title+\"_Ball_FK_Ctrl\")==True:\n         FKHandA=Title+\"_Ball_FK_Ctrl\"    ;FKCtrls.append(Title+\"_Ball_FK_Ctrl\")\n    elif cmds.objExists(Title+\"_ToeA_FK_Ctrl\")==True:\n         FKHandA = Title +\"_ToeA_FK_Ctrl\" ;FKCtrls.append(Title+\"_ToeA_FK_Ctrl\")\n    #------\n    FKHandB = \"\"\n    if FKHandA == Title +\"_ToeA_FK_Ctrl\":\n        if cmds.objExists( Title +\"_ToeB_FK_Ctrl\")==True:\n             FKHandB = Title + \"_ToeB_FK_Ctrl\" ;FKCtrls.append(Title+\"_ToeB_FK_Ctrl\")\n    elif FKHandA==Title+\"_Ball_FK_Ctrl\":\n             FKHandB = Title + \"_ToeA_FK_Ctrl\" ;FKCtrls.append(Title+\"_ToeA_FK_Ctrl\")\n    #-----------------------------------\n    if  FKHandB == Title + \"_ToeA_FK_Ctrl\":\n        FKHandC = Title + \"_ToeB_FK_Ctrl\" ;FKCtrls.append(Title+\"_ToeB_FK_Ctrl\")\n    #-------------------------------------------------\n    # --------------------------------------------\n    #--------------------------------------------\n    FKOffsets = []\n    #*--------\n    FKUpArmOffset=Title+\"_UpLeg_FK_Offset_Ctrl\" ;FKOffsets.append(FKUpArmOffset)\n    FKForeArmOffset=Title+\"_Knee_FK_Offset_Ctrl\" ;FKOffsets.append(FKForeArmOffset)\n    FKFeetOffset=Title+\"_Feet_FK_Offset_Ctrl\" ;FKOffsets.append(FKFeetOffset)\n    FKHandAOffset=\"\"\n    if cmds.objExists(Title+\"_Ball_FK_Offset_Ctrl\")==True:\n         FKHandAOffset=Title+\"_Ball_FK_Offset_Ctrl\"  ;FKOffsets.append(FKHandAOffset)\n    elif cmds.objExists(Title+\"_ToeA_FK_Offset_Ctrl\")==True:\n         FKHandAOffset = Title+\"_ToeA_FK_Offset_Ctrl\" ;FKOffsets.append(FKHandAOffset)\n    #-----------------------------------------------------------\n    FKHandBOffset=\"\"\n    if  FKHandAOffset == Title+\"_ToeA_FK_Offset_Ctrl\" :\n        if cmds.objExists(Title+\"_ToeB_FK_Offset_Ctrl\")==True:\n             FKHandBOffset = Title+\"_ToeB_FK_Offset_Ctrl\" ;FKOffsets.append(FKHandBOffset)\n    elif FKHandAOffset==Title+\"_Ball_FK_Offset_Ctrl\":\n             FKHandBOffset = Title + \"_ToeA_FK_Offset_Ctrl\";FKOffsets.append(FKHandBOffset)\n    #--------------------------------------------------------------------\n    if FKHandBOffset == Title + \"_ToeA_FK_Offset_Ctrl\":\n             FKHandCOffset = Title + \"_ToeB_FK_Offset_Ctrl\"\n    #-------------------------------------------------------------------------\n    #----------------------------------------\n    #ZeroTransforms(FKOffsets,[1,1,0],[\"x\",\"y\",\"z\"])\n    #----------------------------------------------------\n    Attrs=[AttrCtrl+\".Roll\",AttrCtrl+\".Banking\",AttrCtrl+\".TipRotate\",AttrCtrl+\".MidRotate\",AttrCtrl+\".HeelRotate\"]\n    for u in Attrs:\n        if cmds.objExists(u) == True:\n           cmds.setAttr(u,0)\n    #---------------------------------------------------\n    for t in range(0,5):\n        for u in IKCtrls:\n            if cmds.objExists(u)==True:\n               cmds.matchTransform(u,u+\"_Dock_Loc\")\n    #----------------------------------------------------------\n    # --------------------------------------------------\n    # ---This part ...due to possible states of broken limbs (backwards...)  we might need to neutralize the over twisted controls\n    if cmds.objExists(UplegIK)==True:\n        val = cmds.getAttr(UplegIK + \".rz\")\n        if val < -180:\n            newVal = 360 + val\n            cmds.setAttr(UplegIK + \".rz\", newVal)\n        elif val > 180:\n            newVal = val - 360\n            cmds.setAttr(UplegIK + \".rz\", newVal)\n    #------------------------------------------\n    if cmds.objExists(AttrCtrl+\".IK_FK\")==True:\n       cmds.setAttr(AttrCtrl+\".IK_FK\",0)\n    #------------------------------------------------------\n##--------------------------------\n##--------------------------------\ndef LegFKIK_Matcher(Side,*args):\n    # --------------------------------------------------\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Leg=cmds.textField(\"ATLegTypTx\", q=1, tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Leg+\"_\"+Index\n    AttrCtrl=Title+\"_Attr_Ctrl\"\n    # ------------------------\n    IKJnts=[]\n    UpArmIKJnt = Title + \"_UpLeg_IK_Jnt\"  ;IKJnts.append(UpArmIKJnt)\n    ForeArmIKJnt = Title + \"_Knee_IK_Jnt\" ;IKJnts.append(ForeArmIKJnt)\n    FeetIKJnt = Title + \"_Feet_IK_Jnt\"    ;IKJnts.append(FeetIKJnt)\n    HandAIKJnt=\"\"\n    if cmds.objExists(Title + \"_Ball_IK_Jnt\")==True:\n        HandAIKJnt = Title + \"_Ball_IK_Jnt\" ;IKJnts.append(HandAIKJnt)\n    elif cmds.objExists(Title + \"_ToeA_IK_Jnt\")==True:\n        HandAIKJnt = Title + \"_ToeA_IK_Jnt\" ;IKJnts.append(HandAIKJnt)\n    #------\n    HandBIKJnt=\"\"\n    if HandAIKJnt == (Title + \"_ToeA_IK_Jnt\") :\n        if cmds.objExists( Title + \"_ToeB_IK_Jnt\")==True:\n            HandBIKJnt = Title + \"_ToeB_IK_Jnt\" ;IKJnts.append(HandBIKJnt)\n    elif HandAIKJnt == Title + \"_Ball_IK_Jnt\":\n            HandBIKJnt = Title + \"_ToeA_IK_Jnt\";IKJnts.append(HandBIKJnt)\n    #-------------------------------------\n    if HandBIKJnt == (Title + \"_ToeA_IK_Jnt\"):\n            HandCIKJnt =(Title + \"_ToeB_IK_Jnt\");IKJnts.append(HandCIKJnt)\n    # -------------------------------------------\n    # -------------------------------------------\n    FKCtrls=[]\n    FKUpArm=Title+\"_UpLeg_FK_Ctrl\"  ;FKCtrls.append(FKUpArm)\n    FKForeArm=Title+\"_Knee_FK_Ctrl\" ;FKCtrls.append(FKForeArm)\n    FKFeet=Title+\"_Feet_FK_Ctrl\"    ;FKCtrls.append(FKFeet)\n    #-------\n    FKHandA=\"\"\n    if cmds.objExists(Title+\"_Ball_FK_Ctrl\")==True:\n         FKHandA=Title+\"_Ball_FK_Ctrl\"    ;FKCtrls.append(Title+\"_Ball_FK_Ctrl\")\n    elif cmds.objExists(Title+\"_ToeA_FK_Ctrl\")==True:\n         FKHandA = Title +\"_ToeA_FK_Ctrl\" ;FKCtrls.append(Title+\"_ToeA_FK_Ctrl\")\n    #------\n    FKHandB = \"\"\n    if FKHandA ==(Title +\"_ToeA_FK_Ctrl\"):\n        if cmds.objExists( Title +\"_ToeB_FK_Ctrl\")==True:\n             FKHandB = Title + \"_ToeB_FK_Ctrl\" ;FKCtrls.append(Title+\"_ToeB_FK_Ctrl\")\n    elif FKHandA==(Title+\"_Ball_FK_Ctrl\"):\n             FKHandB = Title + \"_ToeA_FK_Ctrl\" ;FKCtrls.append(Title+\"_ToeA_FK_Ctrl\")\n    #-----------------------------------\n    if  FKHandB == Title + \"_ToeA_FK_Ctrl\":\n        FKHandC = Title + \"_ToeB_FK_Ctrl\" ;FKCtrls.append(Title+\"_ToeB_FK_Ctrl\")\n    #-------------------------------------------------\n    # --------------------------------------------\n    #--------------------------------------------\n    FKOffsets = []\n    #*--------\n    FKUpArmOffset=Title+\"_UpLeg_FK_Offset_Ctrl\" ;FKOffsets.append(FKUpArmOffset)\n    FKForeArmOffset=Title+\"_Knee_FK_Offset_Ctrl\" ;FKOffsets.append(FKForeArmOffset)\n    FKFeetOffset=Title+\"_Feet_FK_Offset_Ctrl\" ;FKOffsets.append(FKFeetOffset)\n    FKHandAOffset=\"\"\n    if cmds.objExists(Title+\"_Ball_FK_Offset_Ctrl\")==True:\n         FKHandAOffset=Title+\"_Ball_FK_Offset_Ctrl\"  ;FKOffsets.append(FKHandAOffset)\n    elif cmds.objExists(Title+\"_ToeA_FK_Offset_Ctrl\")==True:\n         FKHandAOffset = Title+\"_ToeA_FK_Offset_Ctrl\" ;FKOffsets.append(FKHandAOffset)\n    #-----------------------------------------------------------\n    FKHandBOffset=\"\"\n    if  FKHandAOffset == Title+\"_ToeA_FK_Offset_Ctrl\" :\n        if cmds.objExists(Title+\"_ToeB_FK_Offset_Ctrl\")==True:\n             FKHandBOffset = Title+\"_ToeB_FK_Offset_Ctrl\" ;FKOffsets.append(FKHandBOffset)\n    elif FKHandAOffset==Title+\"_Ball_FK_Offset_Ctrl\":\n             FKHandBOffset = Title + \"_ToeA_FK_Offset_Ctrl\";FKOffsets.append(FKHandBOffset)\n    #--------------------------------------------------------------------\n    if FKHandBOffset == Title + \"_ToeA_FK_Offset_Ctrl\":\n             FKHandCOffset = Title + \"_ToeB_FK_Offset_Ctrl\"\n    #-------------------------------------------------------------------------\n    # ----------------------------------------\n    ZeroTransforms(FKOffsets, [1, 1, 0], [\"x\", \"y\", \"z\"])\n    # ----------------------------------------------------\n    #Attrs = [AttrCtrl + \".Roll\", AttrCtrl + \".Banking\", AttrCtrl + \".TipRotate\", AttrCtrl + \".MidRotate\",AttrCtrl + \".HeelRotate\"]\n    #for u in Attrs:\n        #cmds.setAttr(u, 0)\n    # ---------------------------------------------------\n    for t in range(0,4):\n        for u in range(0,len(FKCtrls)):\n           if cmds.objExists(FKCtrls[u])==True:\n             if cmds.objExists(IKJnts[u])==True:\n               if cmds.objExists(IKJnts[u]+\"_Dock_Loc\") ==True:\n                  cmds.matchTransform(FKCtrls[u], IKJnts[u]+\"_Dock_Loc\")\n                  #--------------------------------------------------\n                  #---This part ...due to possible states of broken limbs (backwards...)  we might need to neutralize the over twisted controls\n                  val=cmds.getAttr(FKCtrls[u]+\".rz\")\n                  if val <-180:\n                      newVal=360+val\n                      cmds.setAttr(FKCtrls[u]+\".rz\",newVal)\n                  elif val>180:\n                      newVal=val-360\n                      cmds.setAttr(FKCtrls[u]+\".rz\",newVal)\n    #---------------------------------------------------------------------\n    if cmds.objExists(AttrCtrl + \".IK_FK\")==True:\n       cmds.setAttr(AttrCtrl + \".IK_FK\", 10)\n    # ------------------------------------------------------\n#------------------------------------\n#---------\n#--------------------------------------------------\ndef LegMirror(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Leg=cmds.textField(\"ATLegTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n        OppSide=LtSide\n    else:\n        Side=LtSide\n        OppSide=RtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Leg+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n        opp = u.replace(\"_\"+Side+\"_\",\"_\"+OppSide+\"_\")\n        try:\n            for Att in range(0, len(Attrs)):\n                val = cmds.getAttr(u + \".\" + Attrs[Att])\n                cmds.setAttr(opp + \".\" + Attrs[Att], val)\n        except:\n            print(\"\")\n#--------------------------------------------------\ndef LegFlip(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Leg=cmds.textField(\"ATLegTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n        OppSide=LtSide\n    else:\n        Side=LtSide\n        OppSide=RtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Leg+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n        opp = u.replace(\"_\"+Side+\"_\",\"_\"+OppSide+\"_\")\n        try:\n            for Att in range(0,len(Attrs)):\n                val =cmds.getAttr(u + \".\" + Attrs[Att])\n                valB=cmds.getAttr(opp + \".\" + Attrs[Att])\n                cmds.setAttr(opp + \".\" + Attrs[Att], val)\n                cmds.setAttr(u + \".\" + Attrs[Att], valB)\n        except:\n            print(\"\")\n#--------------------------------------------------------------------\n#--------------------------------------------------------------------\ndef LegReset(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Leg=cmds.textField(\"ATLegTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Leg+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n        try:\n            for Att in range(0, len(Attrs)):\n                val = cmds.attributeQuery(Attrs[Att],node=u,ld=True)\n                cmds.setAttr(u + \".\" + Attrs[Att], val[0])\n        except:\n            print(\"\")\n#------------------------------------------------------\ndef LegKey(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Leg=cmds.textField(\"ATLegTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Leg+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        cmds.setKeyframe(u)\n#------------------------------------------------------\ndef LegSelect(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Leg=cmds.textField(\"ATLegTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Leg+\"_\"+Index\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n     if cmds.objExists(u) == True:\n        cmds.select(u,add=1)\n#------------------------------------------------------\ndef LegDelKey(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Leg=cmds.textField(\"ATLegTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Leg+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        cmds.cutKey(u,cl=1)\n#------------------------------------------------------\n#---------------------------------------------------\n#-----------------------------------------------------------\n#----Fingers Part ------------\n#----------------------------------------------\ndef FingersMirror(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Fng=cmds.textField(\"ATFingerTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n        OppSide=LtSide\n    else:\n        Side=LtSide\n        OppSide=RtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Fng+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    #------------------------------------------\n    if cmds.objExists(Title+\"_Cup_Ctrl\")==True:\n        opp = (Title+\"_Cup_Ctrl\").replace(\"_\" + Side + \"_\", \"_\" + OppSide + \"_\");print(\"This is the Opposite..\"+opp)\n        #----------------------------------------\n        x=cmds.getAttr(Title+\"_Cup_Ctrl.rx\")\n        cmds.setAttr(opp+\".rx\",-x)\n        #-----\n        y=cmds.getAttr(Title+\"_Cup_Ctrl.ry\")\n        cmds.setAttr(opp+\".ry\",y)\n        #------------------------------------\n        z=cmds.getAttr(Title+\"_Cup_Ctrl.rz\")\n        cmds.setAttr(opp+\".rz\",-z)\n    #------------------------------------\n    for u in them:\n        if u !=(Title+\"_Cup_Ctrl\"):\n          if cmds.objExists(u) == True:\n            Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n            opp = u.replace(\"_\"+Side+\"_\",\"_\"+OppSide+\"_\")\n            try:\n                for Att in range(0, len(Attrs)):\n                    val = cmds.getAttr(u + \".\" + Attrs[Att])\n                    cmds.setAttr(opp + \".\" + Attrs[Att], val)\n            except:\n                print(\"\")\n    #---------------------------------------------------------\n#---------------------------------------------------------\n#--------------------------------------------------\ndef FingersFlip(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Fng=cmds.textField(\"ATFingerTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n        OppSide=LtSide\n    else:\n        Side=LtSide\n        OppSide=RtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Fng+\"_\"+Index\n    #-------------------------------------------\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    #------------------------------------------------\n    #------------------------------------------\n    if cmds.objExists(Title+\"_Cup_Ctrl\")==True:\n        opp = (Title+\"_Cup_Ctrl\").replace(\"_\" + Side + \"_\", \"_\" + OppSide + \"_\");print(\"This is the Opposite..\"+opp)\n        #---------------------------------------------------------\n        vx=cmds.getAttr(Title+\"_Cup_Ctrl.rx\")\n        vxB=cmds.getAttr(opp+\".rx\")\n        cmds.setAttr(Title+\"_Cup_Ctrl.rx\",-vxB)\n        cmds.setAttr(opp + \".rx\",-vx)\n        #-----------------------------------------------\n        vx=cmds.getAttr(Title+\"_Cup_Ctrl.ry\")\n        vxB=cmds.getAttr(opp+\".ry\")\n        cmds.setAttr(Title+\"_Cup_Ctrl.ry\",vxB)\n        cmds.setAttr(opp + \".ry\",vx)\n        #-----------------------------------------------\n        vx=cmds.getAttr(Title+\"_Cup_Ctrl.rz\")\n        vxB=cmds.getAttr(opp+\".rz\")\n        cmds.setAttr(Title+\"_Cup_Ctrl.rz\",-vxB)\n        cmds.setAttr(opp + \".rz\",-vx)\n        #-----------------------------------------------\n        #----------------------------------------\n    for u in them:\n        if u !=(Title+\"_Cup_Ctrl\"):\n         if cmds.objExists(u) == True:\n            Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n            opp = u.replace(\"_\"+Side+\"_\",\"_\"+OppSide+\"_\")\n            try:\n                for Att in range(0,len(Attrs)):\n                    val =cmds.getAttr(u + \".\" + Attrs[Att])\n                    valB=cmds.getAttr(opp + \".\" + Attrs[Att])\n                    cmds.setAttr(opp + \".\" + Attrs[Att], val)\n                    cmds.setAttr(u + \".\" + Attrs[Att], valB)\n            except:\n                print(\"\")\n#-------------------------------------------\n#--------------------------------------------------------------------\ndef FingersReset(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Fng=cmds.textField(\"ATFingerTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Fng+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n        try:\n            for Att in range(0, len(Attrs)):\n                val = cmds.attributeQuery(Attrs[Att],node=u,ld=True)\n                cmds.setAttr(u + \".\" + Attrs[Att], val[0])\n        except:\n            print(\"\")\n#-------------------------------------------------------------------\n#--------------------------------------------------------------------\ndef FingersSelect(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Fng=cmds.textField(\"ATFingerTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Fng+\"_\"+Index\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n         cmds.select(u,add=1)\n#---------------------------------------------------\ndef FingersKey(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Fng=cmds.textField(\"ATFingerTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Fng+\"_\"+Index\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n         cmds.setKeyframe(u)\n#---------------------------------------\ndef FingersDelKey(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Fng=cmds.textField(\"ATFingerTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n    else:\n        Side=LtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Fng+\"_\"+Index\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n         cmds.cutKey(u,cl=1)\n#---------------------------------------\n#---------------------------------------------------\n#------------------------------------------------------------------\n#-----------------------------------------------------------\n#----Toes Part ------------\n#----------------------------------------------\ndef ToesMirror(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Fng=cmds.textField(\"ATFingerTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    Toe=cmds.textField(\"ATToeTypTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n        OppSide=LtSide\n    else:\n        Side=LtSide\n        OppSide=RtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Fng+\"_\"+Index+\"_\"+Toe\n    #-------------------------------------------\n    them = cmds.ls(Title+\"*_\"+Ctrls)\n    #------------------------------------------\n    if cmds.objExists(Title+\"_Cup_Ctrl\")==True:\n        opp = (Title+\"_Cup_Ctrl\").replace(\"_\" + Side + \"_\", \"_\" + OppSide + \"_\");print(\"This is the Opposite..\"+opp)\n        #----------------------------------------\n        x=cmds.getAttr(Title+\"_Cup_Ctrl.rx\")\n        cmds.setAttr(opp+\".rx\",-x)\n        #-----\n        y=cmds.getAttr(Title+\"_Cup_Ctrl.ry\")\n        cmds.setAttr(opp+\".ry\",y)\n        #------------------------------------\n        z=cmds.getAttr(Title+\"_Cup_Ctrl.rz\")\n        cmds.setAttr(opp+\".rz\",-z)\n    #------------------------------------\n    for u in them:\n        if u !=(Title+\"_Cup_Ctrl\"):\n          if cmds.objExists(u) == True:\n            Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n            opp = u.replace(\"_\"+Side+\"_\",\"_\"+OppSide+\"_\")\n            try:\n                for Att in range(0, len(Attrs)):\n                    val = cmds.getAttr(u + \".\" + Attrs[Att])\n                    cmds.setAttr(opp + \".\" + Attrs[Att], val)\n            except:\n                print(\"\")\n    #---------------------------------------------------------\n#---------------------------------------------------------\n#--------------------------------------------------\ndef ToesFlip(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Fng=cmds.textField(\"ATFingerTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    Toe=cmds.textField(\"ATToeTypTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n        OppSide=LtSide\n    else:\n        Side=LtSide\n        OppSide=RtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Fng+\"_\"+Index+\"_\"+Toe\n    #-------------------------------------------\n    them = cmds.ls(Title+\"*_\"+Ctrls)\n    #------------------------------------------------\n    #------------------------------------------\n    if cmds.objExists(Title+\"_Cup_Ctrl\")==True:\n        opp = (Title+\"_Cup_Ctrl\").replace(\"_\" + Side + \"_\", \"_\" + OppSide + \"_\");print(\"This is the Opposite..\"+opp)\n        #---------------------------------------------------------\n        vx=cmds.getAttr(Title+\"_Cup_Ctrl.rx\")\n        vxB=cmds.getAttr(opp+\".rx\")\n        cmds.setAttr(Title+\"_Cup_Ctrl.rx\",-vxB)\n        cmds.setAttr(opp + \".rx\",-vx)\n        #-----------------------------------------------\n        vx=cmds.getAttr(Title+\"_Cup_Ctrl.ry\")\n        vxB=cmds.getAttr(opp+\".ry\")\n        cmds.setAttr(Title+\"_Cup_Ctrl.ry\",vxB)\n        cmds.setAttr(opp + \".ry\",vx)\n        #-----------------------------------------------\n        vx=cmds.getAttr(Title+\"_Cup_Ctrl.rz\")\n        vxB=cmds.getAttr(opp+\".rz\")\n        cmds.setAttr(Title+\"_Cup_Ctrl.rz\",-vxB)\n        cmds.setAttr(opp + \".rz\",-vx)\n        #-----------------------------------------------\n        #----------------------------------------\n    for u in them:\n        if u !=(Title+\"_Cup_Ctrl\"):\n         if cmds.objExists(u) == True:\n            Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n            opp = u.replace(\"_\"+Side+\"_\",\"_\"+OppSide+\"_\")\n            try:\n                for Att in range(0,len(Attrs)):\n                    val =cmds.getAttr(u + \".\" + Attrs[Att])\n                    valB=cmds.getAttr(opp + \".\" + Attrs[Att])\n                    cmds.setAttr(opp + \".\" + Attrs[Att], val)\n                    cmds.setAttr(u + \".\" + Attrs[Att], valB)\n            except:\n                print(\"\")\n#-------------------------------------------\n#--------------------------------------------------------------------\ndef ToesReset(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Fng=cmds.textField(\"ATFingerTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    Toe=cmds.textField(\"ATToeTypTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n        OppSide=LtSide\n    else:\n        Side=LtSide\n        OppSide=RtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Fng+\"_\"+Index+\"_\"+Toe\n    #-------------------------------------------------------------\n    them = cmds.ls(Title+\"*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        print(u)\n        Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n        try:\n            for Att in range(0, len(Attrs)):\n                val = cmds.attributeQuery(Attrs[Att],node=u,ld=True)\n                cmds.setAttr(u + \".\" + Attrs[Att], val[0])\n        except:\n            print(\"\")\n#---------------------------------------------------\ndef ToesSelect(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Fng=cmds.textField(\"ATFingerTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    Toe=cmds.textField(\"ATToeTypTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n        OppSide=LtSide\n    else:\n        Side=LtSide\n        OppSide=RtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Fng+\"_\"+Index+\"_\"+Toe\n    #-------------------------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        cmds.select(u,add=1)\n#--------------------------------------------\n#---------------------------------------------------\ndef ToesKey(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Fng=cmds.textField(\"ATFingerTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    Toe=cmds.textField(\"ATToeTypTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n        OppSide=LtSide\n    else:\n        Side=LtSide\n        OppSide=RtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Fng+\"_\"+Index+\"_\"+Toe\n    #-------------------------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"*_\"+Ctrls)\n    for u in them:\n       if cmds.objExists(u) == True:\n          cmds.setKeyframe(u)\n#----------------------------------------------------------\ndef ToesDelKey(Side,*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #----------\n    RtSide=cmds.textField(\"ATRtNameTx\",q=1,tx=1)\n    LtSide = cmds.textField(\"ATLtNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Fng=cmds.textField(\"ATFingerTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    Toe=cmds.textField(\"ATToeTypTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #----------------------------------------------\n    if Side==\"Right\":\n        Side=RtSide\n        OppSide=LtSide\n    else:\n        Side=LtSide\n        OppSide=RtSide\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+Side+\"_\"+Fng+\"_\"+Index+\"_\"+Toe\n    #-------------------------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"*_\"+Ctrls)\n    for u in them:\n       if cmds.objExists(u) == True:\n          cmds.cutKey(u)\n#----------------------------------------------------------\n##----==============================================================\n#----------------------------------------------------------\n#-----Neck Part -------\ndef NeckReset(*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #------------------------------------\n    #--------------------------------\n    MidSide=cmds.textField(\"ATMidNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Neck=cmds.textField(\"ATNeckTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+MidSide+\"_\"+Neck+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n        try:\n            for Att in range(0, len(Attrs)):\n                val = cmds.attributeQuery(Attrs[Att],node=u,ld=True)\n                cmds.setAttr(u + \".\" + Attrs[Att], val[0])\n        except:\n            print(\"\")\n#----------------------------------------------------\ndef NeckSelect(*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #------------------------------------\n    #--------------------------------\n    MidSide=cmds.textField(\"ATMidNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Neck=cmds.textField(\"ATNeckTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+MidSide+\"_\"+Neck+\"_\"+Index\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n        if cmds.objExists(u) == True:\n           cmds.select(u,add=1)\n#----------------------------------------------------\ndef Neckkey(*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #------------------------------------\n    #--------------------------------\n    MidSide=cmds.textField(\"ATMidNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Neck=cmds.textField(\"ATNeckTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+MidSide+\"_\"+Neck+\"_\"+Index\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n        if cmds.objExists(u) == True:\n           cmds.setKeyframe(u)\n#----------------------------------------------------\ndef NeckDelkey(*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #------------------------------------\n    #--------------------------------\n    MidSide=cmds.textField(\"ATMidNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Neck=cmds.textField(\"ATNeckTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+MidSide+\"_\"+Neck+\"_\"+Index\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n        if cmds.objExists(u) == True:\n           cmds.cutKey(u,cl=1)\n#----------------------------------------------------\n#----------------------------------------------------------\n#---Spine Part----\ndef SpineReset(*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #------------------------------------\n    #--------------------------------\n    MidSide=cmds.textField(\"ATMidNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Spine=cmds.textField(\"ATSpineTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+MidSide+\"_\"+Spine+\"_\"+Index\n    #-------------------------------------------\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u) == True:\n        Attrs = cmds.listAttr(u, hd=1, k=1, se=1, u=1, v=1, c=1)\n        try:\n            for Att in range(0, len(Attrs)):\n                val = cmds.attributeQuery(Attrs[Att],node=u,ld=True)\n                cmds.setAttr(u + \".\" + Attrs[Att], val[0])\n        except:\n            print(\"\")\n#----------------------------------------------------\ndef SpineSelect(*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #------------------------------------\n    #--------------------------------\n    MidSide=cmds.textField(\"ATMidNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Spine=cmds.textField(\"ATSpineTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+MidSide+\"_\"+Spine+\"_\"+Index\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n        if cmds.objExists(u) == True:\n           cmds.select(u,add=1)\n#-------\ndef Spinekey(*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #------------------------------------\n    #--------------------------------\n    MidSide=cmds.textField(\"ATMidNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Spine=cmds.textField(\"ATSpineTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+MidSide+\"_\"+Spine+\"_\"+Index\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u)==True:\n         cmds.setKeyframe(u)\n#---------------------------------------\ndef SpineDelkey(*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #------------------------------------\n    #--------------------------------\n    MidSide=cmds.textField(\"ATMidNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Spine=cmds.textField(\"ATSpineTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName+\"_\"+MidSide+\"_\"+Spine+\"_\"+Index\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n      if cmds.objExists(u)==True:\n         print(u)\n         cmds.cutKey(u,cl=True)\n##-----------------------------------------------------\n##-----------------------------------------------------\n#----Master ===Mass actions\ndef MasterSelect(*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #------------------------------------\n    #--------------------------------\n    MidSide=cmds.textField(\"ATMidNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Spine=cmds.textField(\"ATSpineTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n        if cmds.objExists(u) == True:\n           cmds.select(u,add=1)\n#-----------------------------------\ndef Masterkey(*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #------------------------------------\n    #--------------------------------\n    MidSide=cmds.textField(\"ATMidNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Spine=cmds.textField(\"ATSpineTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n        if cmds.objExists(u) == True:\n           cmds.setKeyframe(u)\n#------------------------------------------------\ndef MasterDelkey(*args):\n    UseNameSpace=cmds.checkBox(\"ATUseNameSpace\",q=1,v=1)\n    CurrNameSpace=cmds.optionMenu(\"ATNameSpacesOptnMenu\",q=1,v=1)\n    CharName=cmds.optionMenu(\"ATCharactersOptnMenu\",q=1,v=1)\n    #------------------------------------\n    #--------------------------------\n    MidSide=cmds.textField(\"ATMidNameTx\", q=1, tx=1)\n    Index=cmds.textField(\"ATRigIndexTx\", q=1, tx=1)\n    Spine=cmds.textField(\"ATSpineTypTx\", q=1, tx=1)\n    Ctrls=cmds.textField(\"ATCtrlTx\",q=1,tx=1)\n    #-----------\n    if UseNameSpace==True:\n        Pref=CurrNameSpace+\":\"\n    else:\n        Pref=\"\"\n    #-----------------------------------------\n    if CharName==None:\n       CharName=\"\"\n    #------------------------------------------\n    Title=Pref+CharName\n    #-------------------------------------------\n    cmds.select(cl=1)\n    them = cmds.ls(Title+\"_*_\"+Ctrls)\n    for u in them:\n        if cmds.objExists(u) == True:\n           cmds.cutKey(u,cl=1)\n#----------------------------------------------------\ndef MasterReset(*args):\n    ArmReset(\"Right\")\n    ArmReset(\"Left\")\n    LegReset(\"Right\")\n    LegReset(\"Left\")\n    FingersReset(\"Right\")\n    FingersReset(\"Left\")\n    ToesReset(\"Right\")\n    ToesReset(\"Left\")\n    SpineReset()\n    NeckReset()\n#---------------------------------------------------------------\n#--------------------------------------------------------------------\n####UI Elements  ---------------------------------\nif cmds.window(\"SRFAnimTools\",exists=True) :\n    cmds.deleteUI(\"SRFAnimTools\")\n    #cmds.windowPref( 'ShalabyRigs', remove=True )\n\nAnimTools_GUI=cmds.window(\"SRFAnimTools\",t=\"SRF AnimTools\",sizeable=1,w=250,h=250)\ncmds.showWindow(AnimTools_GUI)\n#-------------------------------------\n#scrollLayout = cmds.scrollLayout(saw=300,horizontalScrollBarThickness=1,verticalScrollBarThickness=1)\n#--------------------------\ncmds.columnLayout(\"ATCol\",adj=1)\n#-----------------------------------------------------------\ncmds.frameLayout(\"ATFrameLayoutNames\",label='Naming',bgc=[0.15,0.15,0.125],collapsable=True)\n#--------\ncmds.checkBox(\"ATUseNameSpace\",l=\" Use NameSpace...\",bgc=[0.2,0.2,0.2])\n#-------------------------------------------------------------\ncmds.rowColumnLayout (\"ATRowColumn\",numberOfColumns=3, columnWidth=[(1,65), (2,37),(3,181)] ,columnAlign=[(1,\"left\"),(2,\"center\"),(3,\"right\")],columnSpacing=[(1,0),(2,0),(3,0)] )\n#------------------------------------\ncmds.text(\"ATNameSpacesTxt\",l=\"NameSpaces:\",h=20,bgc=[0.2,0.2,0.2])\ncmds.button(\"ATNameSpacesSearch\",l=\"Search\",h=20,bgc=[0.5,0.2,0.2],c=GetCurNamespaces)\ncmds.optionMenu(\"ATNameSpacesOptnMenu\",h=20)\n#--------------------------------------------------------------\ncmds.text(\"ATCharactersTxt\",l=\"Characters:\",h=20,bgc=[0.2,0.2,0.2])\ncmds.button(\"ATCharactersSearch\",l=\"Search\",h=20,bgc=[0.4,0.3,0.3],c=GetChars)\ncmds.optionMenu(\"ATCharactersOptnMenu\",h=20)\n#--------------------------------------------------------------\n#------------Names Part ------------------------\ncmds.setParent(\"ATFrameLayoutNames\")\ncmds.frameLayout(\"ATFrameLayoutNamesB\",label='Names Conventions',bgc=[0.15,0.25,0.25],collapsable=True,collapse=True)\n#---\ncmds.rowColumnLayout (\"ATRowColumnB\",numberOfColumns=2, columnWidth=[(1,120), (2,130)] ,columnAlign=[(1,\"left\"),(2,\"center\")])\ncmds.checkBox(\"ATAutoReloadNames\",l=\"Auto Check Names \",h=15,bgc=[0.25,0.25,0.25])\ncmds.button(\"ATReloadNames\",l=\"Manual Check Names\",h=15,w=60,bgc=[0.55,0.35,0.35])\n#-------------\ncmds.setParent(\"ATFrameLayoutNamesB\")\ncmds.rowColumnLayout (\"ATRowColumnC\",numberOfColumns=4, columnWidth=[(1,57),(2,68),(3,57),(4,68)] )\n#----\ncmds.text(\"ATRtName\",l=\"Right Side\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATRtNameTx\",tx=\"Rt\",bgc=[0.2,0.2,0.2])\n#-----\ncmds.text(\"ATLtName\",l=\"Left Side\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATLtNameTx\",tx=\"Lt\",bgc=[0.2,0.2,0.2])\n#-------\ncmds.text(\"ATMidName\",l=\"Mid Side\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATMidNameTx\",tx=\"Mid\",bgc=[0.2,0.2,0.2])\n#-------\n#-----\ncmds.text(\"ATRigIndex\",l=\"Rig Index\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATRigIndexTx\",tx=\"A\",bgc=[0.2,0.2,0.2])\n#-------\n#----\ncmds.text(\"ATArmTyp\",l=\"Arm Type\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATArmTypTx\",tx=\"Arm\",bgc=[0.2,0.2,0.2])\n#----\ncmds.text(\"ATLegTyp\",l=\"Leg Type\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATLegTypTx\",tx=\"Leg\",bgc=[0.2,0.2,0.2])\n#----\ncmds.text(\"ATNeckTyp\",l=\"Neck Type\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATNeckTypTx\",tx=\"Neck\",bgc=[0.2,0.2,0.2])\n#----\ncmds.text(\"ATSpineTyp\",l=\"Spine Type\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATSpineTypTx\",tx=\"Spine\",bgc=[0.2,0.2,0.2])\n#----\ncmds.text(\"ATFingerTyp\",l=\"Finger Type\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATFingerTypTx\",tx=\"Fng\",bgc=[0.2,0.2,0.2])\n#----\ncmds.text(\"ATToeTyp\",l=\"Toe Type\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATToeTypTx\",tx=\"Toe\",bgc=[0.2,0.2,0.2])\n#----\ncmds.text(\"ATKnuckle\",l=\"Knuckle\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATKnuckleTx\",tx=\"Knuckle\",bgc=[0.2,0.2,0.2])\n#----\ncmds.text(\"ATThumb\",l=\"Thumb\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATThumbTx\",tx=\"Thumb\",bgc=[0.2,0.2,0.2])\n#----\ncmds.text(\"ATIndex\",l=\"Index\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATIndexTx\",tx=\"Index\",bgc=[0.2,0.2,0.2])\n#----\ncmds.text(\"ATMiddle\",l=\"Middle\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATMiddleTx\",tx=\"Middle\",bgc=[0.2,0.2,0.2])\n#----\ncmds.text(\"ATRing\",l=\"Ring\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATRingTx\",tx=\"Ring\",bgc=[0.2,0.2,0.2])\n#----\ncmds.text(\"ATPinky\",l=\"Pinky\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATPinkyTx\",tx=\"Pinky\",bgc=[0.2,0.2,0.2])\n#----\ncmds.text(\"ATExtra\",l=\"Extra\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATExtraTx\",tx=\"Extra\",bgc=[0.2,0.2,0.2])\n#----\ncmds.text(\"ATCtrl\",l=\"Controls\",bgc=[0.15,0.15,0.15])\ncmds.textField(\"ATCtrlTx\",tx=\"Ctrl\",bgc=[0.2,0.2,0.2])\n\n#====================================================================================================\ncmds.setParent(\"ATCol\")\ncmds.frameLayout(\"ATFrameLayoutMatch\",label='Match/Mirror/Flip/Reset/Select/Key',bgc=[0.35,0.45,0.525],collapsable=True)\n#-------------------------------------------------------------\n#---Let us use FormLayout  to arrange picker like view\ncmds.formLayout(\"form\")\n#-------------------------------------\n#=======Right Arm Group ===========================================\ncmds.button(\"ATRtArmKey\",l=\"K\",h=13,w=13,bgc=[0.725,0.125,0.2],c=partial(ArmKey,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtArmKey\",\"left\",65),(\"ATRtArmKey\",\"top\",5)])\n#--\ncmds.button(\"ATRtArmDelKey\",l=\"C\",h=14,w=13,bgc=[0.725,0.325,0.5],c=partial(ArmDelKey,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtArmDelKey\",\"left\",78),(\"ATRtArmDelKey\",\"top\",4)])\n#---\ncmds.text(\"ATIKFKRtArmTxt\",l=\"Right Arm\",w=60,bgc=[0.2,0.2,0.2])\ncmds.formLayout(\"form\",edit=True,af=[(\"ATIKFKRtArmTxt\",\"left\",5),(\"ATIKFKRtArmTxt\",\"top\",5)])\n#-----------------------------------------------\ncmds.button(\"ATIKFKRtArm\",l=\"IK>FK\",h=17,w=60,bgc=[0.5,0.7,0.1],c=partial(ArmIKFK_Matcher,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATIKFKRtArm\",\"left\",5),(\"ATIKFKRtArm\",\"top\",18)])\n#----------------------------------------------\ncmds.button(\"ATFKIKRtArm\",l=\"FK>IK\",h=17,w=60,bgc=[0.5,0.3,0.4],c=partial(ArmFKIK_Matcher,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATFKIKRtArm\",\"left\",5),(\"ATFKIKRtArm\",\"top\",35)])\n#----------------------------------------------\ncmds.button(\"ATMirrorRtArm\",l=\"Mirror\",h=17,w=60,bgc=[0.8,0.2,0.2],c=partial(ArmMirror,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATMirrorRtArm\",\"left\",5),(\"ATMirrorRtArm\",\"top\",52)])\n#----------------------------------------------\ncmds.button(\"ATFlipRtArm\",l=\"Flip\",h=17,w=60,bgc=[0.7,0.5,0.4],c=partial(ArmFlip,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATFlipRtArm\",\"left\",5),(\"ATFlipRtArm\",\"top\",68)])\n##------------------------------------------------\ncmds.button(\"ATResetRtArm\",l=\"Reset\",h=17,w=60,bgc=[0.1,0.6,0.8],c=partial(ArmReset,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATResetRtArm\",\"left\",5),(\"ATResetRtArm\",\"top\",85)])\n##------------------------------------------------\n#=======Left Arm Group ================================================================\ncmds.button(\"ATLtArmKey\",l=\"K\",h=13,w=13,bgc=[0.725,0.125,0.2],c=partial(ArmKey,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtArmKey\",\"right\",65),(\"ATLtArmKey\",\"top\",5)])\n#-------\n#--\ncmds.button(\"ATLtArmDelKey\",l=\"C\",h=14,w=13,bgc=[0.725,0.325,0.5],c=partial(ArmDelKey,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtArmDelKey\",\"right\",78),(\"ATLtArmDelKey\",\"top\",4)])\n#---\ncmds.text(\"ATIKFKLtArmTxt\",l=\"Left Arm\",w=60,bgc=[0.2,0.2,0.2])\ncmds.formLayout(\"form\",edit=True,af=[(\"ATIKFKLtArmTxt\",\"right\",5),(\"ATIKFKLtArmTxt\",\"top\",5)])\n#-----------------------------------------------\ncmds.button(\"ATIKFKLtArm\",l=\"IK>FK\",h=17,w=60,bgc=[0.5,0.7,0.1],c=partial(ArmIKFK_Matcher,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATIKFKLtArm\",\"right\",5),(\"ATIKFKLtArm\",\"top\",18)])\n#----------------------------------------------\ncmds.button(\"ATFKIKLtArm\",l=\"FK>IK\",h=17,w=60,bgc=[0.5,0.3,0.4],c=partial(ArmFKIK_Matcher,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATFKIKLtArm\",\"right\",5),(\"ATFKIKLtArm\",\"top\",35)])\n#----------------------------------------------\ncmds.button(\"ATMirrorLtArm\",l=\"Mirror\",h=17,w=60,bgc=[0.8,0.2,0.2],c=partial(ArmMirror,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATMirrorLtArm\",\"right\",5),(\"ATMirrorLtArm\",\"top\",52)])\n#----------------------------------------------\ncmds.button(\"ATFlipLtArm\",l=\"Flip\",h=17,w=60,bgc=[0.7,0.5,0.4],c=partial(ArmFlip,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATFlipLtArm\",\"right\",5),(\"ATFlipLtArm\",\"top\",68)])\n##------------------------------------------------\ncmds.button(\"ATResetLtArm\",l=\"Reset\",h=17,w=60,bgc=[0.1,0.6,0.8],c=partial(ArmReset,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATResetLtArm\",\"right\",5),(\"ATResetLtArm\",\"top\",85)])\n##------------------------------------------------\n#===========Body parts Buttons==============================\ncmds.button(\"ATHeadReset\",l=\"Reset\",h=15,w=33,bgc=[0.225,0.725,0.8],c=NeckReset)\ncmds.formLayout(\"form\",edit=True,af=[(\"ATHeadReset\",\"left\",129),(\"ATHeadReset\",\"top\",3)])\n#-------------------------------\ncmds.button(\"ATHeadKey\",l=\"K\",h=13,w=13,bgc=[0.725,0.125,0.2],c=Neckkey)\ncmds.formLayout(\"form\",edit=True,af=[(\"ATHeadKey\",\"left\",120),(\"ATHeadKey\",\"top\",75)])\n#----------------------------------\n#-------------------------------\ncmds.button(\"ATHeadDelKey\",l=\"C\",h=14,w=13,bgc=[0.725,0.325,0.5],c=NeckDelkey)\ncmds.formLayout(\"form\",edit=True,af=[(\"ATHeadDelKey\",\"left\",155),(\"ATHeadDelKey\",\"top\",73)])\n#--------------------------------------------------------------------------------\ncmds.button(\"ATHead\",l=\"Head\",h=40,w=40,bgc=[0.225,0.425,0.8],c=NeckSelect)\ncmds.formLayout(\"form\",edit=True,af=[(\"ATHead\",\"left\",125),(\"ATHead\",\"top\",20)])\n#-----------------------------------------------\ncmds.button(\"ATNeck\",l=\"\",h=25,w=10,bgc=[0.325,0.425,0.9],en=False)\ncmds.formLayout(\"form\",edit=True,af=[(\"ATNeck\",\"left\",138),(\"ATNeck\",\"top\",61)])\n#-----------------------------------------------\n#-----------------------------------------------\ncmds.button(\"ATSpineKey\",l=\"K\",h=13,w=13,bgc=[0.725,0.725,0.2],c=Spinekey)\ncmds.formLayout(\"form\",edit=True,af=[(\"ATSpineKey\",\"left\",117),(\"ATSpineKey\",\"top\",180)])\n#----------\ncmds.button(\"ATSpineDelKey\",l=\"C\",h=14,w=13,bgc=[0.725,0.325,0.5],c=SpineDelkey)\ncmds.formLayout(\"form\",edit=True,af=[(\"ATSpineDelKey\",\"left\",160),(\"ATSpineDelKey\",\"top\",178)])\n#----------\ncmds.text(\"ATSpineTxt\",l=\"Spine\",w=33,bgc=[0.2,0.2,0.2])\ncmds.formLayout(\"form\",edit=True,af=[(\"ATSpineTxt\",\"left\",128),(\"ATSpineTxt\",\"top\",180)])\ncmds.button(\"ATSpineReset\",l=\"Reset\",h=15,w=40,bgc=[0.225,0.725,0.8],c=SpineReset)\ncmds.formLayout(\"form\",edit=True,af=[(\"ATSpineReset\",\"left\",125),(\"ATSpineReset\",\"top\",193)])\n#------------------------------------------------------------\ncmds.button(\"ATSpine\",l=\"\",h=90,w=50,bgc=[0.325,0.125,0.2],c=SpineSelect)\ncmds.formLayout(\"form\",edit=True,af=[(\"ATSpine\",\"left\",120),(\"ATSpine\",\"top\",88)])\n#-----------------------------------------------\n#--------------------------------\ncmds.button(\"ATRtArm\",l=\"\",h=120,w=15,bgc=[0.025,0.225,0.9],c=partial(ArmSelect,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtArm\",\"left\",100),(\"ATRtArm\",\"top\",88)])\n#-----------------------------------------------\n#--------------------------------\ncmds.button(\"ATLtArm\",l=\"\",h=120,w=15,bgc=[0.025,0.725,0.125],c=partial(ArmSelect,\"left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtArm\",\"left\",175),(\"ATLtArm\",\"top\",88)])\n#-----------------------------------------------\n#--------------------------------\ncmds.button(\"ATRtFng\",l=\"\",h=20,w=20,bgc=[0.75,0.625,0.5],c=partial(FingersSelect,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtFng\",\"left\",95),(\"ATRtFng\",\"top\",210)])\n#-----------------------------------------------\n#--------------------------------\ncmds.button(\"ATLtFng\",l=\"\",h=20,w=20,bgc=[0.625,0.325,0.425],c=partial(FingersSelect,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtFng\",\"left\",175),(\"ATLtFng\",\"top\",210)])\n#-----------------------------------------------\n#--------------------------------\ncmds.button(\"ATRtLeg\",l=\"\",h=120,w=15,bgc=[0.025,0.225,0.9],c=partial(LegSelect,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtLeg\",\"left\",120),(\"ATRtLeg\",\"top\",210)])\n#-----------------------------------------------\n#--------------------------------\ncmds.button(\"ATLtLeg\",l=\"\",h=120,w=15,bgc=[0.025,0.725,0.125],c=partial(LegSelect,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtLeg\",\"left\",145),(\"ATLtLeg\",\"top\",210)])\n#-----------------------------------------------\n#---------------------------------------------------------------\ncmds.button(\"ATRtToe\",l=\"\",h=20,w=30,bgc=[0.4,0.225,0.625],c=partial(ToesSelect,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtToe\",\"left\",105),(\"ATRtToe\",\"top\",332)])\n#-----------------------------------------------\n#--------------------------------\ncmds.button(\"ATLtToe\",l=\"\",h=20,w=30,bgc=[0.6,0.725,0.125],c=partial(ToesSelect,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtToe\",\"left\",145),(\"ATLtToe\",\"top\",332)])\n#-----------------------------------------------\n#-----------------------------------------------\n#=======Right Fingers Group ===========================================\n#----------------------------------------------\n#----------------------------------------------\ncmds.button(\"ATRtFingersKey\",l=\"K\",h=13,w=13,bgc=[0.725,0.125,0.2],c=partial(FingersKey,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtFingersKey\",\"left\",5),(\"ATRtFingersKey\",\"top\",138)])\n#--------\ncmds.button(\"ATRtFingersDelKey\",l=\"C\",h=14,w=13,bgc=[0.725,0.325,0.5],c=partial(FingersDelKey,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtFingersDelKey\",\"left\",18),(\"ATRtFingersDelKey\",\"top\",136)])\n#----------\ncmds.text(\"ATRtFingersTxt\",l=\"Right Fingers\",w=65,bgc=[0.2,0.2,0.2])\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtFingersTxt\",\"left\",5),(\"ATRtFingersTxt\",\"top\",152)])\n#-----------------------------------------------\ncmds.button(\"ATMirrorRtFingers\",l=\"Mirror\",h=17,w=60,bgc=[0.8,0.2,0.2],c=partial(FingersMirror,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATMirrorRtFingers\",\"left\",5),(\"ATMirrorRtFingers\",\"top\",168)])\n#----------------------------------------------\ncmds.button(\"ATFlipRtFingers\",l=\"Flip\",h=17,w=60,bgc=[0.7,0.5,0.4],c=partial(FingersFlip,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATFlipRtFingers\",\"left\",5),(\"ATFlipRtFingers\",\"top\",185)])\n##------------------------------------------------\ncmds.button(\"ATResetRtFingers\",l=\"Reset\",h=17,w=60,bgc=[0.1,0.6,0.8],c=partial(FingersReset,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATResetRtFingers\",\"left\",5),(\"ATResetRtFingers\",\"top\",201)])\n#-----------------------------------------------\n#-----------------------------------------------\n#=======Left Fingers Group ===========================================\n#----------------------------------------------\n#----------------------------------------------\ncmds.button(\"ATLtFingersKey\",l=\"K\",h=13,w=13,bgc=[0.725,0.125,0.2],c=partial(FingersKey,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtFingersKey\",\"right\",5),(\"ATLtFingersKey\",\"top\",138)])\n#---------\ncmds.button(\"ATLtFingersDelKey\",l=\"C\",h=14,w=13,bgc=[0.725,0.325,0.5],c=partial(FingersDelKey,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtFingersDelKey\",\"right\",18),(\"ATLtFingersDelKey\",\"top\",136)])\n#--------\ncmds.text(\"ATLtFingersTxt\",l=\"Left Fingers\",w=65,bgc=[0.2,0.2,0.2])\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtFingersTxt\",\"right\",5),(\"ATLtFingersTxt\",\"top\",152)])\n#-----------------------------------------------\ncmds.button(\"ATMirrorLtFingers\",l=\"Mirror\",h=17,w=60,bgc=[0.8,0.2,0.2],c=partial(FingersMirror,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATMirrorLtFingers\",\"right\",5),(\"ATMirrorLtFingers\",\"top\",168)])\n#--------------------------------------------------\ncmds.button(\"ATFlipLtFingers\",l=\"Flip\",h=17,w=60,bgc=[0.7,0.5,0.4],c=partial(FingersFlip,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATFlipLtFingers\",\"right\",5),(\"ATFlipLtFingers\",\"top\",185)])\n##-------------------------------------------------\ncmds.button(\"ATResetLtFingers\",l=\"Reset\",h=17,w=60,bgc=[0.1,0.6,0.8],c=partial(FingersReset,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATResetLtFingers\",\"right\",5),(\"ATResetLtFingers\",\"top\",201)])\n#-------------------------------------\n#----------------------------------------------------------------\n#=======Right Leg Group ===========================================\n#------------------------------------------------------\n#----------\ncmds.button(\"ATRtLegDelKey\",l=\"C\",h=14,w=13,bgc=[0.725,0.325,0.5],c=partial(LegDelKey,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtLegDelKey\",\"left\",80),(\"ATRtLegDelKey\",\"top\",260)])\n#---------------------\ncmds.button(\"ATRtLegKey\",l=\"K\",h=13,w=13,bgc=[0.725,0.125,0.2],c=partial(LegKey,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtLegKey\",\"left\",65),(\"ATRtLegKey\",\"top\",260)])\n#------\ncmds.text(\"ATIKFKRtLegTxt\",l=\"Right Leg\",w=60,bgc=[0.2,0.2,0.2])\ncmds.formLayout(\"form\",edit=True,af=[(\"ATIKFKRtLegTxt\",\"left\",5),(\"ATIKFKRtLegTxt\",\"top\",260)])\n#-----------------------------------------------\ncmds.button(\"ATIKFKRtLeg\",l=\"IK>FK\",h=17,w=60,bgc=[0.5,0.7,0.1],c=partial(LegIKFK_Matcher,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATIKFKRtLeg\",\"left\",5),(\"ATIKFKRtLeg\",\"top\",275)])\n#----------------------------------------------\ncmds.button(\"ATFKIKRtLeg\",l=\"FK>IK\",h=17,w=60,bgc=[0.5,0.3,0.4],c=partial(LegFKIK_Matcher,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATFKIKRtLeg\",\"left\",5),(\"ATFKIKRtLeg\",\"top\",290)])\n#----------------------------------------------\ncmds.button(\"ATMirrorRtLeg\",l=\"Mirror\",h=17,w=60,bgc=[0.8,0.2,0.2],c=partial(LegMirror,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATMirrorRtLeg\",\"left\",5),(\"ATMirrorRtLeg\",\"top\",306)])\n#----------------------------------------------\ncmds.button(\"ATFlipRtLeg\",l=\"Flip\",h=17,w=60,bgc=[0.7,0.5,0.4],c=partial(LegFlip,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATFlipRtLeg\",\"left\",5),(\"ATFlipRtLeg\",\"top\",323)])\n##------------------------------------------------\ncmds.button(\"ATResetRtLeg\",l=\"Reset\",h=17,w=60,bgc=[0.1,0.6,0.8],c=partial(LegReset,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATResetRtLeg\",\"left\",5),(\"ATResetRtLeg\",\"top\",338)])\n##------------------------------------------------\n#-------------------------------------\n#----------------------------------------------------------------\n#=======Left Leg Group ===========================================\n#--------------------------------------------------------------aoc\ncmds.button(\"ATLtLegDelKey\",l=\"C\",h=14,w=13,bgc=[0.725,0.325,0.5],c=partial(LegDelKey,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtLegDelKey\",\"right\",80),(\"ATLtLegDelKey\",\"top\",260)])\n#----\ncmds.button(\"ATLtLegKey\",l=\"K\",h=13,w=13,bgc=[0.725,0.125,0.2],c=partial(LegKey,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtLegKey\",\"right\",65),(\"ATLtLegKey\",\"top\",260)])\n#-----\ncmds.text(\"ATIKFKLtLegTxt\",l=\"Left Leg\",w=60,bgc=[0.2,0.2,0.2])\ncmds.formLayout(\"form\",edit=True,af=[(\"ATIKFKLtLegTxt\",\"right\",5),(\"ATIKFKLtLegTxt\",\"top\",260)])\n#-----------------------------------------------\ncmds.button(\"ATIKFKLtLeg\",l=\"IK>FK\",h=17,w=60,bgc=[0.5,0.7,0.1],c=partial(LegIKFK_Matcher,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATIKFKLtLeg\",\"right\",5),(\"ATIKFKLtLeg\",\"top\",275)])\n#----------------------------------------------\ncmds.button(\"ATFKIKLtLeg\",l=\"FK>IK\",h=17,w=60,bgc=[0.5,0.3,0.4],c=partial(LegFKIK_Matcher,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATFKIKLtLeg\",\"right\",5),(\"ATFKIKLtLeg\",\"top\",290)])\n#----------------------------------------------\ncmds.button(\"ATMirrorLtLeg\",l=\"Mirror\",h=17,w=60,bgc=[0.8,0.2,0.2],c=partial(LegMirror,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATMirrorLtLeg\",\"right\",5),(\"ATMirrorLtLeg\",\"top\",306)])\n#----------------------------------------------\ncmds.button(\"ATFlipLtLeg\",l=\"Flip\",h=17,w=60,bgc=[0.7,0.5,0.4],c=partial(LegFlip,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATFlipLtLeg\",\"right\",5),(\"ATFlipLtLeg\",\"top\",323)])\n##------------------------------------------------\ncmds.button(\"ATResetLtLeg\",l=\"Reset\",h=17,w=60,bgc=[0.1,0.6,0.8],c=partial(LegReset,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATResetLtLeg\",\"right\",5),(\"ATResetLtLeg\",\"top\",338)])\n##------------------------------------------------\n#-----------------------------------------------\n#-----------------------------------------------\n#=======Right Toes Group ===========================================\n#----------------------------------------------\n#----------------------------------------------\ncmds.button(\"ATRtToesKey\",l=\"K\",h=13,w=13,bgc=[0.725,0.125,0.2],c=partial(ToesKey,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtToesKey\",\"left\",70),(\"ATRtToesKey\",\"top\",370)])\n#-------\ncmds.button(\"ATRtToesDelKey\",l=\"C\",h=14,w=13,bgc=[0.725,0.325,0.5],c=partial(ToesDelKey,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtToesDelKey\",\"left\",84),(\"ATRtToesDelKey\",\"top\",368)])\n#-------\ncmds.text(\"ATRtToesTxt\",l=\"Right Toes\",w=60,bgc=[0.2,0.2,0.2])\ncmds.formLayout(\"form\",edit=True,af=[(\"ATRtToesTxt\",\"left\",10),(\"ATRtToesTxt\",\"top\",370)])\n#-----------------------------------------------\ncmds.button(\"ATMirrorRtToes\",l=\"Mirror\",h=17,w=60,bgc=[0.8,0.2,0.2],c=partial(ToesMirror,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATMirrorRtToes\",\"left\",10),(\"ATMirrorRtToes\",\"top\",385)])\n#----------------------------------------------\ncmds.button(\"ATFlipRtToes\",l=\"Flip\",h=17,w=60,bgc=[0.7,0.5,0.4],c=partial(ToesFlip,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATFlipRtToes\",\"left\",10),(\"ATFlipRtToes\",\"top\",400)])\n##-----------------------------------------------------\ncmds.button(\"ATResetRtToes\",l=\"Reset\",h=17,w=60,bgc=[0.1,0.6,0.8],c=partial(ToesReset,\"Right\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATResetRtToes\",\"left\",10),(\"ATResetRtToes\",\"top\",416)])\n#-----------------------------------------------\n#-----------------------------------------------\n#-----------------------------------------------\n#-----------------------------------------------\n#=======Left Toes Group ===========================================\n#----------------------------------------------\n#----------------------------------------------\ncmds.button(\"ATLtToesKey\",l=\"K\",h=13,w=13,bgc=[0.725,0.125,0.2],c=partial(ToesKey,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtToesKey\",\"right\",70),(\"ATLtToesKey\",\"top\",370)])\n#--------\ncmds.button(\"ATLtToesDelKey\",l=\"C\",h=14,w=13,bgc=[0.725,0.325,0.5],c=partial(ToesDelKey,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtToesDelKey\",\"right\",84),(\"ATLtToesDelKey\",\"top\",368)])\n#--------\ncmds.text(\"ATLtToesTxt\",l=\"Left Toes\",w=60,bgc=[0.2,0.2,0.2])\ncmds.formLayout(\"form\",edit=True,af=[(\"ATLtToesTxt\",\"right\",10),(\"ATLtToesTxt\",\"top\",370)])\n#-----------------------------------------------\ncmds.button(\"ATMirrorLtToes\",l=\"Mirror\",h=17,w=60,bgc=[0.8,0.2,0.2],c=partial(ToesMirror,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATMirrorLtToes\",\"right\",10),(\"ATMirrorLtToes\",\"top\",385)])\n#----------------------------------------------\ncmds.button(\"ATFlipLtToes\",l=\"Flip\",h=17,w=60,bgc=[0.7,0.5,0.4],c=partial(ToesFlip,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATFlipLtToes\",\"right\",10),(\"ATFlipLtToes\",\"top\",400)])\n##------------------------------------------------\ncmds.button(\"ATResetLtToes\",l=\"Reset\",h=17,w=60,bgc=[0.1,0.6,0.8],c=partial(ToesReset,\"Left\"))\ncmds.formLayout(\"form\",edit=True,af=[(\"ATResetLtToes\",\"right\",10),(\"ATResetLtToes\",\"top\",416)])\n#------------------------------------------------------------------\n#================================================================================\n##------Master Reset ---------------------------------\ncmds.button(\"ATResetAll\",l=\"Reset EveryThing\",h=20,w=90,bgc=[0.2,0.4,0.8],c=MasterReset)\ncmds.formLayout(\"form\",edit=True,af=[(\"ATResetAll\",\"left\",100),(\"ATResetAll\",\"top\",413)])\n##------Master Select ---------------------------------\ncmds.button(\"ATSelectAll\",l=\"Select EveryThing\",h=20,w=90,bgc=[0.6,0.4,0.8],c=MasterSelect)\ncmds.formLayout(\"form\",edit=True,af=[(\"ATSelectAll\",\"left\",100),(\"ATSelectAll\",\"top\",395)])\n#-------Master Key-----------------------------------------\ncmds.button(\"ATKeyAll\",l=\"K\",h=13,w=13,bgc=[0.725,0.125,0.2],c=Masterkey)\ncmds.formLayout(\"form\",edit=True,af=[(\"ATKeyAll\",\"left\",140),(\"ATKeyAll\",\"top\",382)])\n#-------Master DelKey-----------------------------------------\ncmds.button(\"ATDelKeyAll\",l=\"C\",h=14,w=13,bgc=[0.725,0.325,0.5],c=MasterDelkey)\ncmds.formLayout(\"form\",edit=True,af=[(\"ATDelKeyAll\",\"left\",154),(\"ATDelKeyAll\",\"top\",380)])\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Set Viexport Default Light Intensity" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "defaultLightIntensity" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "Light.png" 
        -image1 "Light.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "setAttr \"hardwareRenderingGlobals.defaultLightIntensity\" 5;" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
    ;

} 
