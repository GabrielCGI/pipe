{
  "_comment": "Configuration par défaut pour exr_analyzer.py",

  "threshold": 20,
  "jobs": 4,

  "channels": {
    "_comment": "Noms de canaux à chercher pour R/G/B (ordre de priorité)",
    "R": ["R", "r", "red", "beauty.R", "RGBA.R", "Composite.R"],
    "G": ["G", "g", "green", "beauty.G", "RGBA.G", "Composite.G"],
    "B": ["B", "b", "blue", "beauty.B", "RGBA.B", "Composite.B"]
  },

  "metadata_keys": {
    "_comment": "Clés de métadonnées EXR à inspecter selon les moteurs de rendu",

    "hostname": [
      "hostname", "host", "computername", "machine",
      "renderhost", "arnold/host", "vray/renderhost"
    ],
    "gpu_name": [
      "gpu", "gpuname", "gpu_name", "renderdevice",
      "cuda_device", "arnoldgpu", "opencl_device",
      "redshift/gpuname", "vray/gpu_name", "octane/gpu"
    ],
    "cpu_name": [
      "cpu", "cpuname", "cpu_name", "processor",
      "arnold/cpu", "vray/cpu"
    ],
    "xpu_ratio": [
      "xpu", "gpupct", "gpu_pct", "gpu_percent",
      "gpuratio", "gpu_ratio", "cpugpu_split",
      "arnold/xpu_gpu_ratio", "redshift/gpu_ratio"
    ]
  },

  "exports": {
    "auto_html": false,
    "auto_csv":  false,
    "auto_json": false,
    "output_dir": "."
  },

  "gpu_vram_gb": {
    "_comment": "VRAM réelle par GPU (en GB). La correspondance se fait par substring case-insensitive sur le nom détecté dans les métadonnées EXR. Ajouter autant d'entrées que nécessaire.",

	"RTX 5090":           32,
	"RTX 5080":           16,
	"RTX 5070 Ti":        16,
	"RTX 5070":           12,
	"RTX 5060 Ti":         8,
	"RTX 5060":            8,

    "RTX 4090":           24,
    "RTX 4080 SUPER":     16,
    "RTX 4080":           16,
    "RTX 4070 Ti SUPER":  16,
    "RTX 4070 Ti":        12,
    "RTX 4070 SUPER":     12,
    "RTX 4070":           12,
    "RTX 4060 Ti":         8,
    "RTX 4060":            8,

    "RTX 3090 Ti":        24,
    "RTX 3090":           24,
    "RTX 3080 Ti":        12,
    "RTX 3080":           10,
    "RTX 3070 Ti":         8,
    "RTX 3070":            8,
    "RTX 3060 Ti":         8,
    "RTX 3060":           12,

    "RTX 2080 Ti":        11,
    "RTX 2080 SUPER":      8,
    "RTX 2080":            8,
    "RTX 2070 SUPER":      8,
    "RTX 2070":            8,
    "RTX 2060 SUPER":      8,
    "RTX 2060":            6,

    "A6000":              48,
    "A5000":              24,
    "A4000":              16,
    "A2000":              12,
    "A100":               80,
    "A40":                48,
