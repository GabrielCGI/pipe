{
    "version": 1,
    "disable_existing_loggers": true,
    "formatters": {
        "standard": {
            "format": "%(asctime)s [%(levelname)s] %(module)s: %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S"
        },
        "short": {
            "format": "%(asctime)s [%(levelname)s]: %(message)s",
            "datefmt": "%H:%M:%S"
        }
    },
    "handlers": {
        "default": {
            "class": "logging.StreamHandler",
            "formatter": "short",
            "level": "WARNING",
            "stream": "ext://sys.stdout"
        },
        "file": {
            "class": "logging.FileHandler",
            "formatter": "standard",
            "level": "DEBUG",
            "mode": "a",
            "filename": ""
        }
    },
    "loggers": {
        "nuke_license_parser": {
            "handlers": [
                "default",
                "file"
            ],
            "level": "DEBUG",
            "propagate": false
        }
    }
}