{
    "load_package_once": true,
    "enable": "houdini_version == '21.0'",
    "env": 
    [
        { 
            "GSOPS": "R:/pipeline/networkInstall/houdini/GSOPs-2.9.0" 
        },
        {
            "GSOPS_VERSION": "2.9.0"
        },
        {
            "GSPLAT_RENDERER": 
            [
                { "houdini_os == 'windows'" : "$GSOPS/plugin/bin/windows/21.0" },
                { "houdini_os == 'linux'" : "$GSOPS/plugin/bin/linux/21.0" },
                { "houdini_os == 'macos'" : "$GSOPS/plugin/bin/macos/21.0" }
            ]
        },
        { 
            "GSOPS_USER_DATA_DIR" : "$GSOPS/.gsops"
        }
    ],
    "hpath": 
    [ 
        "$GSOPS",
        "$GSPLAT_RENDERER"
    ]
}
